).

constraint_def(
    ends_on_tonic,
    phrase_structure,
    hard,
    100,
    [children_songs, sacred_chant, folk_traditional],
    "Melody ends on tonic"
).

constraint_def(
    antecedent_consequent,
    phrase_structure,
    soft,
    55,
    [classical_period, folk_traditional],
    "Half cadence then full cadence structure"
).

constraint_def(
    strong_beat_stability,
    phrase_structure,
    soft,
    60,
    [classical_period, baroque],
    "Stable tones on strong beats"
).

constraint_def(
    golden_section_climax,
    phrase_structure,
    soft,
    45,
    [classical_period, romantic],
    "Climax at ~62% through piece"
).

constraint_def(
    arch_contour,
    phrase_structure,
    soft,
    50,
    [folk_traditional, children_songs],
    "Rise then fall melodic shape"
).

constraint_def(
    tonic_anchoring,
    phrase_structure,
    soft,
    55,
    [folk_traditional, children_songs],
    "Tonic appears regularly"
).

% ==============================================================================
% MOTIVIC CONSTRAINTS
% ==============================================================================

constraint_def(
    sequence_encouraged,
    motivic,
    soft,
    65,
    [baroque],
    "Encourage at least one melodic sequence"
).

constraint_def(
    sequence_pattern,
    motivic,
    soft,
    50,
    [baroque],
    "Repeated melodic pattern transposed"
).

% ==============================================================================
% IDIOMATIC CONSTRAINTS (Style-specific)
% ==============================================================================

constraint_def(
    max_leaps,
    idiomatic,
    soft,
    70,
    [baroque, minimalist, children_songs, sacred_chant],
    "Limit total number of leaps"
).

constraint_def(
    register_consistency,
    idiomatic,
    soft,
    55,
    [sacred_chant, minimalist],
    "Limit large register jumps"
).

constraint_def(
    avoid_monotony,
    idiomatic,
    soft,
    50,
    [sacred_chant],
    "Avoid long runs in same direction"
).

constraint_def(
    stepwise_approach_to_tonic,
    idiomatic,
    soft,
    50,
    [classical_period],
    "Approach tonic by step"
).

% ==============================================================================
% REGISTRY QUERY FUNCTIONS
% ==============================================================================

% Get all constraints
all_constraints() = Ids =>
    Ids = findall(Id, constraint_def(Id, _, _, _, _, _)).

% Get constraints by category
constraints_by_category(Category) = Ids =>
    Ids = findall(Id, constraint_def(Id, Category, _, _, _, _)).

% Get constraints for a genre
constraints_for_genre(Genre) = Ids =>
    Ids = findall(Id, (constraint_def(Id, _, _, _, Genres, _), member(Genre, Genres))).

% Get hard constraints for a genre
hard_constraints_for_genre(Genre) = Ids =>
    Ids = findall(Id, (constraint_def(Id, _, hard, _, Genres, _), member(Genre, Genres))).

% Get soft constraints for a genre with weights
soft_constraints_for_genre(Genre) = Pairs =>
    Pairs = findall((Id, Weight),
        (constraint_def(Id, _, soft, Weight, Genres, _), member(Genre, Genres))).

% Get constraint metadata
get_constraint_info(Id) = Info =>
    if constraint_def(Id, Cat, Type, Weight, Genres, Desc) then
        Info = $constraint_info(
            id = Id,
            category = Cat,
            type = Type,
            default_weight = Weight,
            genres = Genres,
            description = Desc
        )
    else
        Info = not_found
    end.

% Check if constraint exists
constraint_exists(Id) =>
    constraint_def(Id, _, _, _, _, _).

% Get default weight
default_weight(Id) = Weight =>
    constraint_def(Id, _, _, Weight, _, _).

% Is constraint hard?
is_hard_constraint(Id) =>
    constraint_def(Id, _, hard, _, _, _).

% Is constraint soft?
is_soft_constraint(Id) =>
    constraint_def(Id, _, soft, _, _, _).

% Get all categories
all_categories() = [melodic, harmonic, voice_leading, phrase_structure, motivic, idiomatic].

% Get all genres
all_genres() = [
    classical_period, baroque, romantic, traditional_jazz,
    folk_traditional, contemporary, sacred_chant, children_songs,
    minimalist, modal, blues
].

% Print constraint summary
print_constraint_summary() =>
    println("=== Constraint Registry Summary ==="),
    foreach(Cat in all_categories())
        Ids = constraints_by_category(Cat),
        printf("  %w: %d constraints%n", Cat, length(Ids))
    end,
    println(""),
    foreach(Genre in all_genres())
        Hard = hard_constraints_for_genre(Genre),
        Soft = soft_constraints_for_genre(Genre),
        printf("  %w: %d hard, %d soft%n", Genre, length(Hard), length(Soft))
    end.
