% ==============================================================================
% REGISTRY QUERY FUNCTIONS
% ==============================================================================

% Get all constraints
all_constraints() = Ids =>
    Ids = findall(Id, constraint_def(Id, _, _, _, _, _)).

% Get constraints by category
constraints_by_category(Category) = Ids =>
    Ids = findall(Id, constraint_def(Id, Category, _, _, _, _)).

% Get constraints for a genre
constraints_for_genre(Genre) = Ids =>
    Ids = findall(Id, (constraint_def(Id, _, _, _, Genres, _), member(Genre, Genres))).

% Get hard constraints for a genre
hard_constraints_for_genre(Genre) = Ids =>
    Ids = findall(Id, (constraint_def(Id, _, hard, _, Genres, _), member(Genre, Genres))).

% Get soft constraints for a genre with weights
soft_constraints_for_genre(Genre) = Pairs =>
    Pairs = findall((Id, Weight),
        (constraint_def(Id, _, soft, Weight, Genres, _), member(Genre, Genres))).

% Get constraint metadata
get_constraint_info(Id) = Info =>
    if constraint_def(Id, Cat, Type, Weight, Genres, Desc) then
        Info = $constraint_info(
            id = Id,
            category = Cat,
            type = Type,
            default_weight = Weight,
            genres = Genres,
            description = Desc
        )
    else
        Info = not_found
    end.

% Check if constraint exists
constraint_exists(Id) =>
    constraint_def(Id, _, _, _, _, _).

% Get default weight
default_weight(Id) = Weight =>
    constraint_def(Id, _, _, Weight, _, _).

% Is constraint hard?
is_hard_constraint(Id) =>
    constraint_def(Id, _, hard, _, _, _).

% Is constraint soft?
is_soft_constraint(Id) =>
    constraint_def(Id, _, soft, _, _, _).

% Get all categories
all_categories() = [melodic, harmonic, voice_leading, phrase_structure, motivic, idiomatic, emotional].

% Get all genres
all_genres() = [
    classical_period, baroque, romantic, traditional_jazz,
    folk_traditional, contemporary, sacred_chant, children_songs,
    minimalist, modal, blues, galant, high_classical, sturm_und_drang
].

% Print constraint summary
print_constraint_summary() =>
    println("=== Constraint Registry Summary ==="),
    foreach(Cat in all_categories())
        Ids = constraints_by_category(Cat),
        printf("  %w: %d constraints%n", Cat, length(Ids))
    end,
    println(""),
    foreach(Genre in all_genres())
        Hard = hard_constraints_for_genre(Genre),
        Soft = soft_constraints_for_genre(Genre),
        printf("  %w: %d hard, %d soft%n", Genre, length(Hard), length(Soft))
    end.
