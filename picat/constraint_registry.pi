% constraint_registry.pi - Central registry of all music constraints
% Each constraint is catalogued with metadata for dynamic selection
%
% constraint_def(Id, Category, Type, DefaultWeight, ApplicableGenres, Description)
%   Id: Unique atom identifier
%   Category: melodic | harmonic | voice_leading | phrase_structure | rhythmic | idiomatic
%   Type: hard | soft
%   DefaultWeight: 0-100 (for soft constraints; 100 = always try to satisfy)
%   ApplicableGenres: List of genre atoms where this constraint applies
%   Description: Human-readable description

module constraint_registry.

% ==============================================================================
% MELODIC CONSTRAINTS
% ==============================================================================

constraint_def(
    leap_recovery,
    melodic,
    soft,
    75,
    [classical_period, baroque, folk_traditional, children_songs, sacred_chant],
    "After leap >= 5 semitones, move in opposite direction"
).

constraint_def(
    mostly_stepwise,
    melodic,
    soft,
    70,
    [folk_traditional, children_songs, sacred_chant, minimalist],
    "Prefer stepwise motion (intervals <= 2 semitones)"
).

constraint_def(
    no_consecutive_same_direction_leaps,
    melodic,
    soft,
    80,
    [classical_period, baroque, folk_traditional],
    "Avoid two consecutive leaps in same direction"
).

constraint_def(
    no_augmented_seconds,
    melodic,
    hard,
    100,
    [classical_period, baroque, folk_traditional],
    "Avoid augmented seconds (3 semitones)"
).

constraint_def(
    no_tritone_outline,
    melodic,
    hard,
    100,
    [classical_period, folk_traditional, children_songs],
    "Avoid tritone across 3 consecutive notes"
).

constraint_def(
    approach_climax_by_step,
    melodic,
    soft,
    65,
    [classical_period, baroque],
    "Highest note should be approached stepwise"
).

constraint_def(
    leave_climax_contrary,
    melodic,
    soft,
    60,
    [classical_period],
    "After highest note, descend"
).

constraint_def(
    single_climax,
    melodic,
    soft,
    50,
    [classical_period, folk_traditional],
    "One clear highest point in middle third"
).

constraint_def(
    balanced_motion,
    melodic,
    soft,
    55,
    [classical_period, baroque],
    "Roughly equal ascending and descending intervals"
).

constraint_def(
    max_range,
    melodic,
    hard,
    100,
    [folk_traditional, children_songs, minimalist, sacred_chant],
    "Maximum pitch span (ambitus)"
).

constraint_def(
    min_range,
    melodic,
    hard,
    100,
    [romantic, traditional_jazz, blues],
    "Minimum pitch span for variety"
).

constraint_def(
    min_unique_pitches,
    melodic,
    soft,
    60,
    [romantic, traditional_jazz, contemporary],
    "Minimum number of distinct pitches"
).

constraint_def(
    max_octave_leaps,
    melodic,
    soft,
    70,
    [classical_period, folk_traditional],
    "Limit leaps of octave or larger"
).

constraint_def(
    max_consecutive_repeats,
    melodic,
    hard,
    100,
    [classical_period, baroque, romantic, traditional_jazz, folk_traditional, contemporary, sacred_chant, children_songs, minimalist, modal, blues],
    "Maximum 2 consecutive note repetitions (hard constraint)"
).

constraint_def(
    no_immediate_repeat,
    melodic,
    soft,
    50,
    [classical_period, baroque, romantic],
    "No immediate pitch repetition"
).

