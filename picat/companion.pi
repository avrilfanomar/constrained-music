% companion.pi - Music Companion main orchestrator
%
% Main entry point for generating emotional transition music.
% Coordinates mood planning, segment generation, and output.

module companion.

import mood.
import mood_mapping.
import transition.
import melody.
import music_types.
import violin_types.
import temporal.
import midi_export.
import util.
import genre_profiles.
import constraint_selector.
import form.
import validation.
import humanize.
import motif.
import visualizer.
import harmonizer.
import accompaniment.
import refiner.
import chord_generator.
import ornaments.
import scale_utils.
import rng.

% ==============================================================================
% MAIN ENTRY POINTS
% ==============================================================================

% Main entry point with preset names
main =>
    % Default demonstration: calm to energized, through the full quality path
    % (genre constraints + variable rhythm), not the legacy harmony-blind path
    run_companion_with_genre(mood_preset(calm_peaceful), mood_preset(energized),
                             300, "session.json", 0.0, classical_period, [rhythm=on]).

% Run companion with preset mood names (no randomness)
run_companion_presets(StartPreset, EndPreset, DurationSecs, OutputPath) =>
    run_companion_presets(StartPreset, EndPreset, DurationSecs, OutputPath, 0.0).

% Run companion with preset mood names and randomness
run_companion_presets(StartPreset, EndPreset, DurationSecs, OutputPath, Randomness) =>
    StartMood = mood_preset(StartPreset),
    EndMood = mood_preset(EndPreset),
    run_companion(StartMood, EndMood, DurationSecs, OutputPath, Randomness).

% Main companion function with mood structures (no randomness)
run_companion(StartMood, EndMood, DurationSecs, OutputPath) =>
    run_companion(StartMood, EndMood, DurationSecs, OutputPath, 0.0).

% Main companion function with mood structures and randomness
% Randomness: 0.0 = deterministic, 1.0 = maximum variation
run_companion(StartMood, EndMood, DurationSecs, OutputPath, Randomness) =>
    run_companion(StartMood, EndMood, DurationSecs, OutputPath, Randomness, []).

% Legacy path with preferences (key=/tempo= overrides still honored)
run_companion(StartMood, EndMood, DurationSecs, OutputPath, Randomness, Preferences) =>
    println("=== Music Companion ==="),
    nl,

    % Comprehensive input validation
    catch(
        validation.validate_companion_inputs(StartMood, EndMood, DurationSecs, OutputPath, Randomness),
        ValidationError,
        handle_validation_error(ValidationError)
    ),

    % Print session info
    printf("Generating emotional transition:%n"),
    printf("  From: "), print_mood(StartMood),
    printf("  To:   "), print_mood(EndMood),
    printf("  Duration: %d seconds (%.1f minutes)%n", DurationSecs, DurationSecs / 60.0),
    printf("  Randomness: %.2f%n%n", Randomness),

    % Plan the transition with randomness
    println("Planning transition path..."),
    Segments0 = plan_transition(StartMood, EndMood, DurationSecs, ease_in_out, Randomness),
    Segments = apply_musical_overrides(Segments0, Preferences, true),
    printf("  Created %d segments%n%n", length(Segments)),

    % Generate melodies for each segment
    println("Generating music for each segment..."),
    KeyRoot = get_key_root_from_preferences(Preferences),
    AllNotes = generate_all_segments(Segments, KeyRoot),
    printf("  Generated %d total notes%n%n", length(AllNotes)),

    % Apply velocity curves (phrase-level dynamics per segment)
    println("Applying expression..."),
    ExpressiveNotes = apply_segment_expression(AllNotes, Segments),

    % Apply humanization (velocity jitter; micro-timing is added after the
    % accompaniment merge so both hands share one offset per onset)
    HumanizeIntensity = cond(Randomness > 0.0, min(1.0, Randomness * 1.5), 0.3),
    FinalMelody = humanize.humanize_notes(ExpressiveNotes, HumanizeIntensity),
    printf("  Humanization: %.0f%%%n%n", HumanizeIntensity * 100),

    % Generate accompaniment
    AccompNotes = generate_accompaniment_for_melody(AllNotes, KeyRoot, Segments, none, none),
    FinalNotes = humanize.humanize_ensemble_timing(FinalMelody ++ AccompNotes, HumanizeIntensity),

    % Collect tempo changes for MIDI export
    TempoChanges = collect_tempo_changes(Segments),

    % Generate pedal events (sustain pedal for piano)
    TotalBarsBasic = sum([get_segment_num_bars(S) : S in Segments]),
    PedalEventsBasic = midi_export.generate_pedal_events(TotalBarsBasic),

    % Export to JSON (for Python MIDI writer)
    println("Exporting to JSON..."),
    MetaBasic = build_export_metadata(KeyRoot, Segments, none, StartMood, EndMood, Preferences),
    export_session_json_with_pedal(FinalNotes, TempoChanges, $meter(4, 4), PedalEventsBasic, MetaBasic, OutputPath),
    printf("  Saved to: %s%n%n", OutputPath),

    println("Done! Run midi_writer.py to convert to MIDI."),
    nl.

% ==============================================================================
% MULTIPLE OUTPUT GENERATION
% ==============================================================================

% Generate N different outputs (variations) satisfying the same criteria
run_companion_multiple(StartMood, EndMood, DurationSecs, OutputPath, Randomness, Count, Genre, FormType, Preferences) =>
    printf("=== Generating %d Variations ===%n%n", Count),

    % Validate count
    if Count < 1 then
        println("Error: count must be at least 1"),
        halt(1)
    end,
    if Count > 100 then
        println("Error: count cannot exceed 100"),
        halt(1)
    end,

    % Ensure minimum randomness to guarantee different outputs
    % Without randomness, the CP solver would produce identical results
    MinRandomness = 0.2,
    BaseRandomness = max(Randomness, MinRandomness),
    if Randomness < MinRandomness then
        printf("Note: Using minimum randomness %.2f to ensure distinct variations%n%n", MinRandomness)
    end,

    % Generate each variation with slightly varied randomness for extra diversity
    foreach(I in 1..Count)
        printf("--- Variation %d of %d ---%n", I, Count),
        NumberedPath = output_path_with_number(OutputPath, I, Count),

        % Advance random state to ensure different CP solver results
        % Each iteration consumes random values to diverge the random sequence
        advance_random_state(I * 100),

        % Vary randomness slightly per iteration (within ±0.05) for extra diversity
        VariationOffset = (I - 1) * 0.02,
        IterRandomness = min(1.0, BaseRandomness + VariationOffset),

        % Dispatch to appropriate generator
        if FormType != none, FormType != through then
            run_companion_with_form(StartMood, EndMood, DurationSecs, NumberedPath, IterRandomness, FormType, Genre, Preferences)
        elseif Genre != none then
            run_companion_with_genre(StartMood, EndMood, DurationSecs, NumberedPath, IterRandomness, Genre, Preferences)
        else
            run_companion(StartMood, EndMood, DurationSecs, NumberedPath, IterRandomness, Preferences)
        end,

        if I < Count then nl end
    end,

    printf("%n=== Generated %d variations ===%n", Count),
    printf("Output files: %s%n", describe_output_files(OutputPath, Count)).

% Generate numbered output path: session.json -> session_1.json, session_2.json, etc.
output_path_with_number(BasePath, Index, TotalCount) = NumberedPath =>
    % Only add number suffix if generating multiple outputs
    if TotalCount == 1 then
        NumberedPath = BasePath
    else
        % Check if path ends with .json
        if append(Prefix, ".json", BasePath) then
            NumberedPath = Prefix ++ "_" ++ to_string(Index) ++ ".json"
        else
            % No .json extension, just append number
            NumberedPath = BasePath ++ "_" ++ to_string(Index)
        end
    end.

% Describe output files for summary message
describe_output_files(BasePath, Count) = Description =>
    if Count == 1 then
        Description = BasePath
    else
        FirstPath = output_path_with_number(BasePath, 1, Count),
        LastPath = output_path_with_number(BasePath, Count, Count),
        Description = FirstPath ++ " ... " ++ LastPath
    end.

% Advance random state by consuming N random values
% This ensures different CP solver results for each iteration
% (rng-aware: consumes the seeded stream when seed= is active, so
% count=N variations stay reproducible under a fixed seed)
advance_random_state(N) =>
    foreach(_ in 1..N)
        _ = rng.rand_int()
    end.

% ==============================================================================
% GENRE-BASED COMPANION
% ==============================================================================

% Run companion with genre-based constraint optimization
run_companion_with_genre(StartMood, EndMood, DurationSecs, OutputPath, Randomness, Genre, Preferences) =>
    println("=== Music Companion (Genre Mode) ==="),
    nl,

    % Comprehensive input validation
    catch(
        validation.validate_companion_inputs(StartMood, EndMood, DurationSecs, OutputPath, Randomness),
        ValidationError,
        handle_validation_error(ValidationError)
    ),

    % Validate genre
    if not genre_profiles.genre_exists(Genre) then
        printf("Error: Unknown genre '%w'%n", Genre),
        printf("Available genres: %w%n", genre_profiles.all_genres()),
        halt(1)
    end,

    % Print session info
    printf("Generating emotional transition:%n"),
    printf("  From: "), print_mood(StartMood),
    printf("  To:   "), print_mood(EndMood),
    printf("  Duration: %d seconds (%.1f minutes)%n", DurationSecs, DurationSecs / 60.0),
    printf("  Genre: %w%n", Genre),
    printf("  Randomness: %.2f%n%n", Randomness),

    % Plan the transition
    println("Planning transition path..."),
    Segments0 = plan_transition(StartMood, EndMood, DurationSecs, ease_in_out, Randomness),
    Segments = apply_musical_overrides(Segments0, Preferences, true),
    printf("  Created %d segments%n%n", length(Segments)),

    % Generate melodies with genre constraints
    println("Generating music with genre constraints..."),
    KeyRoot = get_key_root_from_preferences(Preferences),

    % Per-piece refinement: generate entire piece N times, keep best
    PieceRounds = refiner.get_refine_piece_rounds(Preferences),
    if PieceRounds > 1 then
        printf("  Per-piece refinement (%d rounds)...%n", PieceRounds),
        % Round 1
        (PieceNotes1, PiecePlan1) = generate_all_segments_with_genre(Segments, KeyRoot, Genre, Preferences),
        PiecePitches1 = refiner.extract_pitches(PieceNotes1),
        PieceScore1 = refiner.score_for_refinement(PiecePitches1, KeyRoot, Genre, Preferences),
        printf("  Piece round 1: score=%d (%d notes)%n", PieceScore1, length(PieceNotes1)),
        BestPieceNotes = PieceNotes1,
        BestPiecePlan = PiecePlan1,
        BestPieceScore = PieceScore1,
        % Rounds 2..N
        foreach(PR in 2..PieceRounds)
            advance_random_state(PR * 137),
            (PieceNotesR, PiecePlanR) = generate_all_segments_with_genre(Segments, KeyRoot, Genre, Preferences),
            PiecePitchesR = refiner.extract_pitches(PieceNotesR),
            PieceScoreR = refiner.score_for_refinement(PiecePitchesR, KeyRoot, Genre, Preferences),
            printf("  Piece round %d: score=%d (%d notes)%n", PR, PieceScoreR, length(PieceNotesR)),
            if PieceScoreR < BestPieceScore then
                BestPieceScore := PieceScoreR,
                BestPieceNotes := PieceNotesR,
                BestPiecePlan := PiecePlanR
            end
        end,
        PieceImprovePct = cond(PieceScore1 > 0, (PieceScore1 - BestPieceScore) * 100 // PieceScore1, 0),
        printf("  -> Selected best piece (score=%d, -%d%% vs round 1)%n", BestPieceScore, PieceImprovePct),
        AllNotes = BestPieceNotes,
        ChordPlan = BestPiecePlan
    else
        (AllNotes, ChordPlan) = generate_all_segments_with_genre(Segments, KeyRoot, Genre, Preferences)
    end,
    printf("  Generated %d total notes%n%n", length(AllNotes)),

    % Apply velocity curves (phrase-level dynamics per segment)
    println("Applying expression..."),
    ExpressiveNotes = apply_segment_expression(AllNotes, Segments),

    % Apply phrase-level dynamic arcs
    TotalBarsForPlan = sum([get_segment_num_bars(S) : S in Segments]),
    DynamicsPlan = humanize.make_standard_plan(TotalBarsForPlan, 80),
    PlannedNotes = humanize.apply_dynamics_plan(ExpressiveNotes, DynamicsPlan),

    % Apply humanization
    HumanizeIntensity = cond(Randomness > 0.0, min(1.0, Randomness * 1.5), 0.3),
    HumanizedNotes0 = humanize.humanize_notes(PlannedNotes, HumanizeIntensity),
    printf("  Humanization: %.0f%%%n%n", HumanizeIntensity * 100),

    % Phrase breathing: release each phrase-final note early (audible rests
    % between phrases; accompaniment sustains through the gap)
    HumanizedNotes = humanize.add_phrase_breathing(HumanizedNotes0, ChordPlan),

    % Add ornaments (genre-appropriate grace notes, diatonic in each bar's key)
    OrnamentDensity = get_ornament_density(Preferences),
    OrnMeter = get_meter_from_preferences(Preferences),
    FinalMelody = ornaments.add_ornaments(HumanizedNotes, Genre, OrnamentDensity, ChordPlan, OrnMeter),
    if OrnamentDensity > 0.0 then
        OrnCount = length(FinalMelody) - length(HumanizedNotes),
        if OrnCount > 0 then
            printf("  Ornaments: %d grace notes added%n", OrnCount)
        end
    end,

    % Generate accompaniment from the same chord plan the melody used
    AccompPattern = get_accomp_preference(Preferences),
    AccompNotes = generate_accompaniment_from_plan(AllNotes, ChordPlan, Genre, AccompPattern),
    % Shared micro-timing over the merged stream: one offset per onset, so
    % melody and accompaniment land together (per-part jitter caused flams)
    FinalNotes = humanize.humanize_ensemble_timing(FinalMelody ++ AccompNotes, HumanizeIntensity),

    % Collect tempo changes
    TempoChanges = collect_tempo_changes(Segments, Preferences),

    % Extract meter for export (default 4/4)
    ExportMeter = get_meter_from_preferences(Preferences),

    % Generate pedal events (sustain pedal for piano)
    TotalBarsGenre = sum([get_segment_num_bars(S) : S in Segments]),
    PedalEvents = midi_export.generate_pedal_events(TotalBarsGenre),

    % Export to JSON
    println("Exporting to JSON..."),
    MetaGenre = build_export_metadata(KeyRoot, Segments, Genre, StartMood, EndMood, Preferences),
    export_session_json_with_pedal(FinalNotes, TempoChanges, ExportMeter, PedalEvents, MetaGenre, OutputPath),
    printf("  Saved to: %s%n%n", OutputPath),

    % Print constraint violation report
    visualizer.print_violation_report(AllNotes, KeyRoot, Genre),

    println("Done! Run midi_writer.py to convert to MIDI."),
    nl.

% Piece-level register arc: each segment gets a target register center on an
% arc rising toward the piece climax and falling after; the climax segment
% must touch the PIECE climax pitch (an absolute pitch, the same for the
% whole piece) and every other segment is capped just below it, so the piece
% has ONE highest moment. The climax lands on the segment whose mood-driven
% voice reaches highest (an arousal ramp climaxes at the end, like a real
% crescendo piece); among equally-high segments the golden-ratio one wins.
register_arc_prefs(Params, SegIndex, TotalSegs, ClimaxIdx, PieceClimax) = RegPrefs =>
    Voice = get_voice(Params),
    Voice = $voice(_, _, _, $range(Low, High)),
    T = (SegIndex - 0.5) / max(1, TotalSegs),
    Peak = 0.618,
    Arc = 1.0 - abs(T - Peak) / max(Peak, 1.0 - Peak),
    % Arc breadth 0.34..0.68 of the voice range (was 0.30..0.70): corpus
    % pieces span ~11-18 semitones; the wider arc pushed whole pieces to 22+
    Center = Low + round((0.34 + 0.34 * Arc) * (High - Low)),
    if SegIndex == ClimaxIdx then
        RegPrefs = [register_center=Center, register_span=4, climax_target=PieceClimax]
    else
        RegPrefs = [register_center=Center, register_span=4, register_ceiling=PieceClimax - 2]
    end.

% Index of the segment nearest the golden ratio of the piece
climax_segment_index(TotalSegs) = max(1, min(TotalSegs, round(0.618 * TotalSegs))).

% The comfortable top of a segment's voice (its own potential climax)
segment_own_climax(Seg) = P =>
    Params = get_segment_params(Seg),
    Voice = get_voice(Params),
    Voice = $voice(_, _, _, $range(Low, High)),
    P = Low + round(0.82 * (High - Low)).

% Snap the raw (range-derived) piece-climax pitch DOWN to a scale tone of
% the climax segment's key. The 85%-of-voice-range point is usually not in
% the scale at all, and melody.apply_register_arc now HARD-requires the
% climax segment to reach target-1 — the target must be an attainable pitch.
snap_climax_to_scale(RawP, SegKeyRoot, Mode) = Snapped =>
    ScaleBelow = scale_utils.scale_notes_in_range(SegKeyRoot, Mode, RawP - 11, RawP),
    if ScaleBelow != [] then
        Snapped = max(ScaleBelow)
    else
        Snapped = RawP
    end.

% Choose the climax segment and the absolute piece-climax pitch: the segment
% whose voice tops out highest; ties broken toward the golden-ratio index.
choose_climax_segment(Segments) = (ClimaxIdx, PieceClimax) =>
    N = length(Segments),
    Climaxes = [segment_own_climax(S) : S in Segments],
    PieceClimax = max(Climaxes),
    Golden = climax_segment_index(N),
    BestIdx = 0,
    BestDist = N + 1,
    foreach(I in 1..N)
        if Climaxes[I] == PieceClimax, abs(I - Golden) < BestDist then
            BestIdx := I,
            BestDist := abs(I - Golden)
        end
    end,
    ClimaxIdx = BestIdx.

% Last pitch to connect the next segment to, scanning back through Acc
% (most-recent-first) past any segment whose generation fully failed (an
% empty melody) so a solver failure doesn't crash last_pitch on last([]).
find_prev_last_pitch([]) = none.
find_prev_last_pitch([Melody | Rest]) = Result =>
    if Melody != [] then
        Result = melody.last_pitch(Melody)
    else
        Result = find_prev_last_pitch(Rest)
    end.

% Generate segments with genre-based constraints (with motif memory)
% Returns (AllNotes, ChordPlan): ChordPlan is the list of $chord_span() entries
% describing the progression each segment's melody was constrained against,
% so the accompaniment can play the exact same chords.
generate_all_segments_with_genre(Segments, KeyRoot, Genre, Preferences) = (AllNotes, ChordPlan) =>
    TotalSegs = length(Segments),
    (ClimaxIdxG, RawClimaxG) = choose_climax_segment(Segments),
    ClimaxModeG = get_mode(get_segment_params(Segments[ClimaxIdxG])),
    ClimaxInfo = (ClimaxIdxG, snap_climax_to_scale(RawClimaxG, KeyRoot, ClimaxModeG)),
    (AllNotes, ChordPlan) = generate_segments_genre_helper(Segments, KeyRoot, Genre, Preferences, 1, 0, [], [], [], TotalSegs, ClimaxInfo).

generate_segments_genre_helper([], _, _, _, _, _, Acc, _MotifIntervals, PlanAcc, _TotalSegs, _ClimaxInfo) = (flatten(reverse(Acc)), reverse(PlanAcc)).
generate_segments_genre_helper([Seg | Rest], KeyRoot, Genre, Preferences, SegIndex, CurrentBar, Acc, MotifIntervals, PlanAcc, TotalSegs, ClimaxInfo) = Result =>
    NumBars = get_segment_num_bars(Seg),
    Params = get_segment_params(Seg),
    MotifWeight = 80,  % Weight per phrase start lacking a motif statement

    % Inject segment mood into preferences for emotional constraints
    SegmentMood = get_segment_mood(Seg),

    % Piece-level register arc (single absolute climax pitch for the piece)
    (ClimaxIdx, PieceClimax) = ClimaxInfo,
    RegPrefs = register_arc_prefs(Params, SegIndex, TotalSegs, ClimaxIdx, PieceClimax),

    % Plan the segment's chord progression up front (single source of harmonic
    % truth: melody solve and accompaniment both use this exact progression)
    SegMode = get_mode(Params),
    SegDegrees = chord_generator.plan_progression(NumBars, SegMode, Genre, get_randomness(Params)),
    ChordSpan = $chord_span(CurrentBar, NumBars, KeyRoot, SegMode, SegDegrees),

    % Check if rhythm mode is active
    if find_first_key(Preferences, rhythm, RhythmVal1), RhythmVal1 == on then
        UseRhythm = true
    else
        UseRhythm = false
    end,

    % Determine connection info (skips back past any failed/empty segment)
    PrevLastPitch = find_prev_last_pitch(Acc),

    % Determine refinement rounds
    NumRounds = refiner.get_refine_rounds(Preferences),

    % Round 1: generate normally
    MoodPrefs1 = [mood=SegmentMood, progression=SegDegrees | RegPrefs ++ Preferences],
    SegMelody1 = try_genre_segment(Params, KeyRoot, NumBars, Genre, MoodPrefs1, UseRhythm, PrevLastPitch, MotifIntervals, MotifWeight),

    % Refinement rounds
    if NumRounds > 1, SegMelody1 != [] then
        Pitches1 = refiner.extract_pitches(SegMelody1),
        Score1 = refiner.score_for_refinement(Pitches1, KeyRoot, Genre, Preferences),
        printf("    Refining (%d rounds)...%n", NumRounds),
        printf("    Round 1: score=%d%n", Score1),
        BestScore = Score1,
        BestMelody = SegMelody1,
        foreach(Round in 2..NumRounds)
            advance_random_state(Round * 73),
            BoostedPrefs = refiner.boost_worst_constraints(refiner.extract_pitches(BestMelody), KeyRoot, Genre, Preferences, Round),
            BoostedMoodPrefs = [mood=SegmentMood, progression=SegDegrees | RegPrefs ++ BoostedPrefs],
            % Minimum randomness that enables rand_val labeling for round diversity
            % (optimization always stays on; see constraint_selector.solve_strategy)
            RefinedParams = refiner.ensure_min_randomness(Params, 0.3),
            CandidateMelody = try_genre_segment(RefinedParams, KeyRoot, NumBars, Genre, BoostedMoodPrefs, UseRhythm, PrevLastPitch, MotifIntervals, MotifWeight),
            if CandidateMelody != [] then
                CandidatePitches = refiner.extract_pitches(CandidateMelody),
                % Score with base preferences (not boosted) for fair comparison
                CandidateScore = refiner.score_for_refinement(CandidatePitches, KeyRoot, Genre, Preferences),
                BoostedInfo = refiner.format_boosted(BoostedPrefs),
                printf("    Round %d: score=%d%s%n", Round, CandidateScore, BoostedInfo),
                if CandidateScore < BestScore then
                    BestScore := CandidateScore,
                    BestMelody := CandidateMelody
                end
            else
                printf("    Round %d: generation failed, skipping%n", Round)
            end
        end,
        ImprovePct = cond(Score1 > 0, (Score1 - BestScore) * 100 // Score1, 0),
        printf("    -> Selected best (score=%d, -%d%% vs round 1)%n", BestScore, ImprovePct),
        SegmentMelody = BestMelody
    else
        SegmentMelody = SegMelody1
    end,

    % Extract motif from first segment
    NewMotifIntervals = cond(MotifIntervals == [],
        motif.extract_motif(SegmentMelody, motif.default_motif_length()),
        MotifIntervals),

    % Print motif info on first segment
    if Acc == [], NewMotifIntervals != [] then
        printf("  Segment %2d: bars %3d-%3d, tempo=%3d, genre=%w%n",
               SegIndex, CurrentBar + 1, CurrentBar + NumBars,
               get_tempo(Params), Genre),
        motif.print_motif(NewMotifIntervals)
    else
        printf("  Segment %2d: bars %3d-%3d, tempo=%3d, genre=%w%n",
               SegIndex, CurrentBar + 1, CurrentBar + NumBars,
               get_tempo(Params), Genre)
    end,
    % Register diagnostic: the piece should have ONE top — every non-climax
    % segment stays at/below ceiling, the climax segment reaches its target
    if SegmentMelody != [] then
        SegMaxP = max(refiner.extract_pitches(SegmentMelody)),
        if SegIndex == ClimaxIdx then
            printf("    register: seg max=%d, CLIMAX target=%d%n", SegMaxP, PieceClimax)
        else
            printf("    register: seg max=%d, ceiling=%d%n", SegMaxP, PieceClimax - 2)
        end
    end,
    if melody.is_periodic_progression(SegDegrees, NumBars) then
        PeriodTag = " (period: A A')"
    else
        PeriodTag = ""
    end,
    printf("    harmony: %s%s%n",
           chord_generator.format_progression(SegDegrees, SegMode), PeriodTag),

    % Adjust timing
    TimedMelody = [adjust_note_bar(Note, CurrentBar) : Note in SegmentMelody],

    Result = generate_segments_genre_helper(Rest, KeyRoot, Genre, Preferences, SegIndex + 1, CurrentBar + NumBars, [TimedMelody | Acc], NewMotifIntervals, [ChordSpan | PlanAcc], TotalSegs, ClimaxInfo).

% ==============================================================================
% SEGMENT GENERATION HELPERS (for refinement)
% ==============================================================================

% Try one genre segment generation attempt
% PrevLastPitch = none for first segment, MIDI pitch otherwise
% Returns melody notes or [] on failure
try_genre_segment(Params, KeyRoot, NumBars, Genre, MoodPrefs, UseRhythm, PrevLastPitch, MotifIntervals, MotifWeight) = SegmentMelody =>
    if PrevLastPitch == none then
        % First segment: no connection needed
        if UseRhythm == true,
           once(melody.generate_segment_melody_with_rhythm(Params, KeyRoot, NumBars, Genre, MoodPrefs, M1)) then
            SegmentMelody = M1
        elseif once(melody.generate_segment_melody_with_genre(Params, KeyRoot, NumBars, Genre, MoodPrefs, M2)) then
            SegmentMelody = M2
        else
            SegmentMelody = last_resort_segment(Params, KeyRoot, NumBars, Genre, MoodPrefs)
        end
    else
        % Connect to previous segment with motif reference
        if UseRhythm == true, MotifIntervals != [],
           once(melody.generate_connected_segment_with_rhythm_and_motif(Params, KeyRoot, NumBars, PrevLastPitch, Genre, MoodPrefs, MotifIntervals, MotifWeight, M3)) then
            SegmentMelody = M3
        elseif UseRhythm == true,
           once(melody.generate_connected_segment_with_rhythm(Params, KeyRoot, NumBars, PrevLastPitch, Genre, MoodPrefs, M4)) then
            SegmentMelody = M4
        elseif MotifIntervals != [],
           once(melody.generate_connected_segment_with_motif(Params, KeyRoot, NumBars, PrevLastPitch, Genre, MoodPrefs, MotifIntervals, MotifWeight, M5)) then
            SegmentMelody = M5
        elseif once(melody.generate_connected_segment_with_genre(Params, KeyRoot, NumBars, PrevLastPitch, Genre, MoodPrefs, M6)) then
            SegmentMelody = M6
        elseif once(melody.generate_segment_melody_with_genre(Params, KeyRoot, NumBars, Genre, MoodPrefs, M7)) then
            % Fallback: generate without connection
            SegmentMelody = M7
        else
            SegmentMelody = last_resort_segment(Params, KeyRoot, NumBars, Genre, MoodPrefs)
        end
    end.

% Last-resort net: a segment must NEVER come back empty (an empty melody
% renders as bars of accompaniment playing alone). Stage 1 (climax segments
% only): keep the climax target but drop the top-band cap (climax_topcount=off)
% — the piece still rises to its designed high point, it may just touch it
% more than 3 times. Stage 2: strip climax/ceiling/recall entirely — the
% harmonic plan (progression=) and register center are kept, so the segment
% still fits the piece; it just gives up the special climax/recall duties.
last_resort_segment(Params, KeyRoot, NumBars, Genre, MoodPrefs) = SegmentMelody =>
    if find_first_key(MoodPrefs, climax_target, _),
       once(melody.generate_segment_melody_with_genre(Params, KeyRoot, NumBars, Genre, [climax_topcount = off | MoodPrefs], MC)) then
        printf("    [warn] all segment shapes failed; retried without climax top-band cap%n"),
        SegmentMelody = MC
    else
        RelaxedPrefs = [P : P in MoodPrefs, not strippable_pref(P)],
        if once(melody.generate_segment_melody_with_genre(Params, KeyRoot, NumBars, Genre, RelaxedPrefs, MR)) then
            printf("    [warn] all segment shapes failed; used relaxed constraints (no climax/recall)%n"),
            SegmentMelody = MR
        else
            printf("    [warn] segment unsolvable even relaxed; melody left empty%n"),
            SegmentMelody = []
        end
    end.

strippable_pref(climax_target = _) => true.
strippable_pref(register_ceiling = _) => true.
strippable_pref(recall_pitches = _) => true.
strippable_pref(_) => fail.

% ==============================================================================
% FORM-BASED COMPANION
% ==============================================================================
% Generate music within a formal structure (binary, ternary, rondo)
% Mood transitions happen within form section boundaries

% Run companion with form structure
run_companion_with_form(StartMood, EndMood, DurationSecs, OutputPath, Randomness, FormType) =>
    run_companion_with_form(StartMood, EndMood, DurationSecs, OutputPath, Randomness, FormType, none, []).

% Run companion with form structure and genre
run_companion_with_form(StartMood, EndMood, DurationSecs, OutputPath, Randomness, FormType, Genre, Preferences) =>
    println("=== Music Companion (Form Mode) ==="),
    nl,

    % Validate moods
    if not is_valid_mood(StartMood) then
        throw($error(invalid_start_mood, StartMood))
    end,
    if not is_valid_mood(EndMood) then
        throw($error(invalid_end_mood, EndMood))
    end,

    % Print session info
    printf("Generating emotional transition with form structure:%n"),
    printf("  From: "), print_mood(StartMood),
    printf("  To:   "), print_mood(EndMood),
    printf("  Duration: %d seconds (%.1f minutes)%n", DurationSecs, DurationSecs / 60.0),
    printf("  Form: %s%n", form.form_description(FormType)),
    printf("  Randomness: %.2f%n", Randomness),
    if Genre != none then
        printf("  Genre: %w%n", Genre),
        StyleOverridesInfo = get_style_overrides(Preferences, Genre),
        if StyleOverridesInfo != [] then
            printf("  Section contrast: "),
            foreach(I in 1..length(StyleOverridesInfo))
                StyleOverridesInfo[I] = (SL=SG),
                printf("%w=%w", SL, SG),
                if I < length(StyleOverridesInfo) then printf(", ") end
            end,
            nl
        end
    end,
    nl,

    % Calculate approximate number of bars from average tempo
    % (a forced tempo= drives section sizing so total duration stays right)
    if find_first_key(Preferences, force_tempo, TempoOverrideForm) then
        AvgTempo = TempoOverrideForm
    else
        TempoOverrideForm = none,
        AvgMood = mood_lerp(StartMood, EndMood, 0.5),
        AvgParams = mood_to_params(AvgMood),
        AvgTempo = get_tempo(AvgParams)
    end,
    SecondsPerBar = 240.0 / AvgTempo,  % 4 beats per bar
    TotalBars = max(8, round(DurationSecs / SecondsPerBar)),

    % Get key root and mode (artist overrides win over mood defaults)
    KeyRoot = get_key_root_from_preferences(Preferences),
    if find_first_key(Preferences, force_mode, ForcedModeForm) then
        InitialMode = ForcedModeForm
    else
        InitialParams = mood_to_params(StartMood),
        InitialMode = get_mode(InitialParams)
    end,

    % Get form sections
    FormSections = form.get_form_sections(FormType, TotalBars, KeyRoot mod 12, InitialMode),
    println("Form structure:"),
    form.print_form_structure(FormType, FormSections),
    nl,

    % Plan transition within form sections
    println("Planning transition within form sections..."),
    SegmentsF0 = plan_transition_within_form(StartMood, EndMood, DurationSecs, ease_in_out, Randomness, FormSections, TempoOverrideForm),
    % Bar counts are locked to form sections: force tempo/mode without resizing
    Segments = apply_musical_overrides(SegmentsF0, Preferences, false),
    printf("  Created %d segments across %d sections%n%n", length(Segments), length(FormSections)),

    % Generate melodies with form awareness
    println("Generating music for each segment..."),
    (AllNotes, ChordPlanForm) = generate_all_segments_with_form(Segments, FormSections, KeyRoot, Genre, Preferences),
    printf("  Generated %d total notes%n%n", length(AllNotes)),

    % Apply velocity curves (phrase-level dynamics per segment)
    println("Applying expression..."),
    ExpressiveNotes = apply_segment_expression(AllNotes, Segments),

    % Apply phrase-level dynamic arcs
    TotalBarsPlanForm = sum([get_segment_num_bars(S) : S in Segments]),
    DynamicsPlanForm = humanize.make_standard_plan(TotalBarsPlanForm, 80),
    PlannedNotesForm = humanize.apply_dynamics_plan(ExpressiveNotes, DynamicsPlanForm),

    % Apply humanization
    HumanizeIntensity = cond(Randomness > 0.0, min(1.0, Randomness * 1.5), 0.3),
    HumanizedNotesForm0 = humanize.humanize_notes(PlannedNotesForm, HumanizeIntensity),
    printf("  Humanization: %.0f%%%n%n", HumanizeIntensity * 100),

    % Phrase breathing: release each phrase-final note early (audible rests
    % between phrases; accompaniment sustains through the gap)
    HumanizedNotesForm = humanize.add_phrase_breathing(HumanizedNotesForm0, ChordPlanForm),

    % Add ornaments (genre-appropriate grace notes, diatonic in each bar's key)
    if Genre != none then
        OrnamentDensityForm = get_ornament_density(Preferences),
        OrnMeterForm = get_meter_from_preferences(Preferences),
        FinalMelody = ornaments.add_ornaments(HumanizedNotesForm, Genre, OrnamentDensityForm, ChordPlanForm, OrnMeterForm),
        OrnCountForm = length(FinalMelody) - length(HumanizedNotesForm),
        if OrnCountForm > 0 then
            printf("  Ornaments: %d grace notes added%n", OrnCountForm)
        end
    else
        FinalMelody = HumanizedNotesForm
    end,

    % Generate accompaniment from the same chord plan the melody used
    % (uses each section's transposed key, so accompaniment follows modulations)
    AccompPattern = cond(Genre != none, get_accomp_preference(Preferences), none),
    AccompNotes = generate_accompaniment_from_plan(AllNotes, ChordPlanForm, Genre, AccompPattern),
    % Shared micro-timing over the merged stream: one offset per onset, so
    % melody and accompaniment land together (per-part jitter caused flams)
    FinalNotes = humanize.humanize_ensemble_timing(FinalMelody ++ AccompNotes, HumanizeIntensity),

    % Collect tempo changes
    TempoChanges = collect_tempo_changes(Segments, Preferences),

    % Extract meter for export (default 4/4)
    ExportMeter2 = get_meter_from_preferences(Preferences),

    % Generate pedal events (sustain pedal for piano)
    TotalBarsForm = sum([get_segment_num_bars(S) : S in Segments]),
    PedalEventsForm = midi_export.generate_pedal_events(TotalBarsForm),

    % Export to JSON
    println("Exporting to JSON..."),
    MetaForm = build_export_metadata(KeyRoot, Segments, Genre, StartMood, EndMood, Preferences),
    export_session_json_with_pedal(FinalNotes, TempoChanges, ExportMeter2, PedalEventsForm, MetaForm, OutputPath),
    printf("  Saved to: %s%n%n", OutputPath),

    println("Done! Run midi_writer.py to convert to MIDI."),
    nl.

% Plan transition aligned to form section boundaries
plan_transition_within_form(StartMood, EndMood, DurationSecs, EasingType, Randomness, FormSections) = AllSegments =>
    AllSegments = plan_transition_within_form(StartMood, EndMood, DurationSecs, EasingType, Randomness, FormSections, none).

plan_transition_within_form(StartMood, EndMood, DurationSecs, EasingType, Randomness, FormSections, TempoOverride) = AllSegments =>
    % Calculate total bars from form sections
    TotalBars = sum([form.section_bars(S) : S in FormSections]),

    % Calculate seconds per bar based on average tempo (or forced tempo=)
    if TempoOverride != none then
        AvgTempo = TempoOverride
    else
        AvgMood = mood_lerp(StartMood, EndMood, 0.5),
        AvgParams = mood_to_params(AvgMood),
        AvgTempo = get_tempo(AvgParams)
    end,
    SecondsPerBar = 240.0 / AvgTempo,

    % Generate segments for each form section
    AllSegments = generate_form_section_segments(FormSections, StartMood, EndMood,
                                                  DurationSecs, SecondsPerBar,
                                                  EasingType, Randomness, TotalBars, 0, 1, []).

% Generate segments for each form section
generate_form_section_segments([], _, _, _, _, _, _, _, _, _, Acc) = flatten(reverse(Acc)).
generate_form_section_segments([Section | RestSections], StartMood, EndMood,
                                TotalDuration, SecondsPerBar, EasingType, Randomness,
                                TotalBars, CurrentBar, SegIndex, Acc) = Result =>
    SectionBars = form.section_bars(Section),
    SectionKey = form.section_key(Section),
    SectionMode = form.section_mode(Section),
    SectionLabel = form.section_label(Section),

    % Calculate what fraction of the piece this section represents
    SectionStartFrac = CurrentBar / TotalBars,
    SectionEndFrac = (CurrentBar + SectionBars) / TotalBars,

    % Calculate mood at section boundaries
    SectionStartMood = mood_lerp(StartMood, EndMood, apply_easing(SectionStartFrac, EasingType)),
    SectionEndMood = mood_lerp(StartMood, EndMood, apply_easing(SectionEndFrac, EasingType)),

    % Calculate section duration
    SectionDuration = SectionBars * SecondsPerBar,

    % Create segments within this section (aim for ~15-20 second segments)
    TargetSegmentDuration = 17.0,
    NumSectionSegments = max(1, round(SectionDuration / TargetSegmentDuration)),
    SegmentDuration = SectionDuration / NumSectionSegments,
    BarsPerSegment = max(1, SectionBars // NumSectionSegments),

    % Generate segments for this section
    SectionSegments = create_section_segments(NumSectionSegments, SegmentDuration, BarsPerSegment,
                                               SectionStartMood, SectionEndMood,
                                               SectionKey, SectionMode, SectionLabel,
                                               Randomness, SegIndex, CurrentBar,
                                               length(RestSections) == 0),

    NextSegIndex = SegIndex + NumSectionSegments,
    Result = generate_form_section_segments(RestSections, StartMood, EndMood,
                                            TotalDuration, SecondsPerBar, EasingType, Randomness,
                                            TotalBars, CurrentBar + SectionBars, NextSegIndex,
                                            [SectionSegments | Acc]).

% Create segments within a single form section
create_section_segments(NumSegments, SegmentDuration, BarsPerSegment,
                        SectionStartMood, SectionEndMood, SectionKey, SectionMode, SectionLabel,
                        Randomness, StartIndex, StartBar, IsFinalSection) = Segments =>
    Segments = [create_form_segment(I, NumSegments, SegmentDuration, BarsPerSegment,
                                     SectionStartMood, SectionEndMood,
                                     SectionKey, SectionMode, SectionLabel,
                                     Randomness, StartIndex, StartBar,
                                     cond(IsFinalSection, I == NumSegments, false))
                : I in 1..NumSegments].

% Create a single segment within a form section
create_form_segment(LocalIndex, NumLocalSegments, SegmentDuration, BarsPerSegment,
                    SectionStartMood, SectionEndMood, SectionKey, SectionMode, SectionLabel,
                    Randomness, GlobalStartIndex, SectionStartBar, IsFinalSegment) = Segment =>
    % Calculate position within section
    T = (LocalIndex - 0.5) / NumLocalSegments,

    % Interpolate mood within section
    SegmentMood = mood_lerp(SectionStartMood, SectionEndMood, T),

    % Get base music params and override mode from form section
    BaseParams = mood_to_params(SegmentMood, Randomness),
    Params = override_mode(BaseParams, SectionMode),

    % Calculate timing
    GlobalIndex = GlobalStartIndex + LocalIndex - 1,
    StartTime = (LocalIndex - 1) * SegmentDuration,
    StartBar = SectionStartBar + (LocalIndex - 1) * BarsPerSegment,

    % Use form section bars (handle remainder in last segment)
    NumBars = BarsPerSegment,

    % Create segment with form context
    Segment = $form_segment(GlobalIndex, StartTime, SegmentDuration, SegmentMood, Params, NumBars,
                            SectionKey, SectionMode, SectionLabel, IsFinalSegment).

% Override mode in music params
override_mode(music_params(Tempo, _, Density, Interval, Voice, VelBase, VelVar, Legato, Diss, Rand), NewMode) =
    $music_params(Tempo, NewMode, Density, Interval, Voice, VelBase, VelVar, Legato, Diss, Rand).

% Accessors for form_segment
get_form_segment_key(form_segment(_, _, _, _, _, _, K, _, _, _)) = K.
get_form_segment_mode(form_segment(_, _, _, _, _, _, _, M, _, _)) = M.
get_form_segment_label(form_segment(_, _, _, _, _, _, _, _, L, _)) = L.
get_form_segment_is_final(form_segment(_, _, _, _, _, _, _, _, _, F)) = F.

% Segment accessors - handle both form_segment (10 args) and regular segment (6 args)
% Note: In Picat, all clauses of a function must be contiguous

get_segment_index(form_segment(I, _, _, _, _, _, _, _, _, _)) = I.
get_segment_index(segment(I, _, _, _, _, _)) = I.

get_segment_start_time(form_segment(_, T, _, _, _, _, _, _, _, _)) = T.
get_segment_start_time(segment(_, T, _, _, _, _)) = T.

get_segment_duration(form_segment(_, _, D, _, _, _, _, _, _, _)) = D.
get_segment_duration(segment(_, _, D, _, _, _)) = D.

get_segment_mood(form_segment(_, _, _, M, _, _, _, _, _, _)) = M.
get_segment_mood(segment(_, _, _, M, _, _)) = M.

get_segment_params(form_segment(_, _, _, _, P, _, _, _, _, _)) = P.
get_segment_params(segment(_, _, _, _, P, _)) = P.

get_segment_num_bars(form_segment(_, _, _, _, _, N, _, _, _, _)) = N.
get_segment_num_bars(segment(_, _, _, _, _, N)) = N.

% Get style overrides from preferences or use defaults
get_style_overrides(Preferences, BaseGenre) = Overrides =>
    if find_first_key(Preferences, contrast, ContrastVal) then
        if ContrastVal == off then
            Overrides = []
        else
            Overrides = form.default_contrast_styles(BaseGenre)
        end
    else
        % Default: auto contrast for form-based generation
        Overrides = form.default_contrast_styles(BaseGenre)
    end.

% Generate all segments with form awareness (with motif memory and thematic recall)
% Returns (AllNotes, ChordPlan) — see generate_all_segments_with_genre.
generate_all_segments_with_form(Segments, FormSections, KeyRoot, Genre, Preferences) = (AllNotes, ChordPlan) =>
    % Determine style overrides for section contrast
    StyleOverrides = cond(Genre != none, get_style_overrides(Preferences, Genre), []),
    TotalSegsF = length(Segments),
    (ClimaxIdxF0, RawClimaxF) = choose_climax_segment(Segments),
    ClimaxSegF = Segments[ClimaxIdxF0],
    % Form sections transpose: snap against the climax section's actual key
    ClimaxKeyF = KeyRoot + get_form_segment_key(ClimaxSegF),
    ClimaxModeF0 = get_mode(get_segment_params(ClimaxSegF)),
    ClimaxInfoF = (ClimaxIdxF0, snap_climax_to_scale(RawClimaxF, ClimaxKeyF, ClimaxModeF0)),
    (AllNotes, ChordPlan) = generate_form_segments_helper(Segments, FormSections, KeyRoot, Genre, Preferences, StyleOverrides, 1, 0, [], [], new_map(), new_map(), [], TotalSegsF, ClimaxInfoF).

generate_form_segments_helper([], _, _, _, _, _, _, _, Acc, _MotifIntervals, _SectionPitchMap, _SectionChordMap, PlanAcc, _TotalSegs, _ClimaxInfo) = (flatten(reverse(Acc)), reverse(PlanAcc)).
generate_form_segments_helper([Seg | Rest], FormSections, KeyRoot, Genre, Preferences, StyleOverrides, SegIndex, CurrentBar, Acc, MotifIntervals, SectionPitchMap, SectionChordMap, PlanAcc, TotalSegs, ClimaxInfo) = Result =>
    NumBars = get_segment_num_bars(Seg),
    Params = get_segment_params(Seg),
    MotifWeight = 80,

    % Piece-level register arc (single absolute climax pitch for the piece)
    (ClimaxIdxF, PieceClimaxF) = ClimaxInfo,
    RegPrefsF = register_arc_prefs(Params, SegIndex, TotalSegs, ClimaxIdxF, PieceClimaxF),

    % Get form context
    SectionKey = get_form_segment_key(Seg),
    SectionMode = get_form_segment_mode(Seg),
    SectionLabel = get_form_segment_label(Seg),
    _IsFinal = get_form_segment_is_final(Seg),

    % Determine section-specific genre (style override for contrast)
    if Genre != none then
        SectionGenre = form.section_style(SectionLabel, Genre, StyleOverrides)
    else
        SectionGenre = none
    end,

    % Transpose key root by section key (relative to C)
    TransposedKeyRoot = KeyRoot + SectionKey,

    % Inject segment mood into preferences for emotional constraints
    SegmentMood = get_segment_mood(Seg),

    % Plan the segment's chord progression up front, reusing the progression of
    % a returning section label (ABA) so recalled melodies meet the same harmony.
    SegModeF = get_mode(Params),
    GenreForProgF = cond(SectionGenre != none, SectionGenre, classical_period),
    if SectionChordMap.has_key(SectionLabel), SectionChordMap.get(SectionLabel) = (NumBars, StoredDegreesF) then
        SegDegreesF = StoredDegreesF
    else
        SegDegreesF = chord_generator.plan_progression(NumBars, SegModeF, GenreForProgF, get_randomness(Params))
    end,
    if not SectionChordMap.has_key(SectionLabel) then
        SectionChordMap.put(SectionLabel, (NumBars, SegDegreesF))
    end,
    ChordSpanF = $chord_span(CurrentBar, NumBars, TransposedKeyRoot, SegModeF, SegDegreesF),

    % Check if this section label has been seen before (thematic recall for ABA form)
    % If so, inject recall_pitches into preferences to constrain the return section
    if SectionPitchMap.has_key(SectionLabel) then
        RecallPitchesF = SectionPitchMap.get(SectionLabel),
        printf("  Thematic recall: section '%c' returning (%d pitches, 80%% match)%n", SectionLabel, length(RecallPitchesF)),
        SectionPrefsF = [recall_pitches=RecallPitchesF | Preferences]
    else
        SectionPrefsF = Preferences
    end,

    % Check if rhythm mode is active
    if find_first_key(SectionPrefsF, rhythm, RhythmValF), RhythmValF == on then
        UseRhythmF = true
    else
        UseRhythmF = false
    end,

    % Determine connection info (skips back past any failed/empty segment)
    PrevLastPitchF = find_prev_last_pitch(Acc),

    % Determine refinement rounds (only for genre-based generation)
    NumRoundsF = cond(SectionGenre != none, refiner.get_refine_rounds(SectionPrefsF), 1),

    % Generate melody (genre-based path uses try_genre_segment; non-genre uses direct calls)
    if SectionGenre != none then
        % Genre-based: use try_genre_segment with refinement
        MoodPrefsF1 = [mood=SegmentMood, progression=SegDegreesF | RegPrefsF ++ SectionPrefsF],
        SegMelodyF1 = try_genre_segment(Params, TransposedKeyRoot, NumBars, SectionGenre, MoodPrefsF1, UseRhythmF, PrevLastPitchF, MotifIntervals, MotifWeight),

        if NumRoundsF > 1, SegMelodyF1 != [] then
            PitchesF1 = refiner.extract_pitches(SegMelodyF1),
            ScoreF1 = refiner.score_for_refinement(PitchesF1, TransposedKeyRoot, SectionGenre, SectionPrefsF),
            printf("    Refining (%d rounds)...%n", NumRoundsF),
            printf("    Round 1: score=%d%n", ScoreF1),
            BestScoreF = ScoreF1,
            BestMelodyF = SegMelodyF1,
            foreach(RoundF in 2..NumRoundsF)
                advance_random_state(RoundF * 73),
                BoostedPrefsF = refiner.boost_worst_constraints(refiner.extract_pitches(BestMelodyF), TransposedKeyRoot, SectionGenre, SectionPrefsF, RoundF),
                BoostedMoodPrefsF = [mood=SegmentMood, progression=SegDegreesF | RegPrefsF ++ BoostedPrefsF],
                % Minimum randomness that enables rand_val labeling for round diversity
                % (optimization always stays on; see constraint_selector.solve_strategy)
                RefinedParamsF = refiner.ensure_min_randomness(Params, 0.3),
                CandidateMelodyF = try_genre_segment(RefinedParamsF, TransposedKeyRoot, NumBars, SectionGenre, BoostedMoodPrefsF, UseRhythmF, PrevLastPitchF, MotifIntervals, MotifWeight),
                if CandidateMelodyF != [] then
                    CandidatePitchesF = refiner.extract_pitches(CandidateMelodyF),
                    % Score with base preferences (not boosted) for fair comparison
                    CandidateScoreF = refiner.score_for_refinement(CandidatePitchesF, TransposedKeyRoot, SectionGenre, SectionPrefsF),
                    BoostedInfoF = refiner.format_boosted(BoostedPrefsF),
                    printf("    Round %d: score=%d%s%n", RoundF, CandidateScoreF, BoostedInfoF),
                    if CandidateScoreF < BestScoreF then
                        BestScoreF := CandidateScoreF,
                        BestMelodyF := CandidateMelodyF
                    end
                else
                    printf("    Round %d: generation failed, skipping%n", RoundF)
                end
            end,
            ImprovePctF = cond(ScoreF1 > 0, (ScoreF1 - BestScoreF) * 100 // ScoreF1, 0),
            printf("    -> Selected best (score=%d, -%d%% vs round 1)%n", BestScoreF, ImprovePctF),
            SegmentMelody = BestMelodyF
        else
            SegmentMelody = SegMelodyF1
        end
    else
        % Non-genre: direct generation, no refinement
        if PrevLastPitchF == none then
            once(generate_segment_melody(Params, TransposedKeyRoot, NumBars, SegmentMelody))
        else
            if once(generate_connected_segment_melody(Params, TransposedKeyRoot, NumBars, PrevLastPitchF, SegMelodyF0)) then
                SegmentMelody = SegMelodyF0
            else
                once(generate_segment_melody(Params, TransposedKeyRoot, NumBars, SegmentMelody))
            end
        end
    end,

    % Store section pitches for thematic recall (only first occurrence of each label)
    if not SectionPitchMap.has_key(SectionLabel) then
        SectionPitchesF = motif.extract_pitches_from_melody(SegmentMelody),
        SectionPitchMap.put(SectionLabel, SectionPitchesF)
    end,

    % Extract motif from first segment
    NewMotifIntervals = cond(MotifIntervals == [],
        motif.extract_motif(SegmentMelody, motif.default_motif_length()),
        MotifIntervals),

    % Print segment info with section genre if different from base
    if SectionGenre != none, SectionGenre != Genre then
        printf("  Segment %2d [%c]: bars %3d-%3d, tempo=%3d, key=%s %w, genre=%w%n",
               SegIndex, SectionLabel, CurrentBar + 1, CurrentBar + NumBars,
               get_tempo(Params), pitch_class_name(SectionKey), SectionMode, SectionGenre)
    else
        printf("  Segment %2d [%c]: bars %3d-%3d, tempo=%3d, key=%s %w%n",
               SegIndex, SectionLabel, CurrentBar + 1, CurrentBar + NumBars,
               get_tempo(Params), pitch_class_name(SectionKey), SectionMode)
    end,
    if melody.is_periodic_progression(SegDegreesF, NumBars) then
        PeriodTagF = " (period: A A')"
    else
        PeriodTagF = ""
    end,
    printf("    harmony: %s%s%n",
           chord_generator.format_progression(SegDegreesF, SegModeF), PeriodTagF),

    % Adjust timing
    TimedMelody = [adjust_note_bar(Note, CurrentBar) : Note in SegmentMelody],

    Result = generate_form_segments_helper(Rest, FormSections, KeyRoot, Genre, Preferences, StyleOverrides,
                                           SegIndex + 1, CurrentBar + NumBars, [TimedMelody | Acc], NewMotifIntervals, SectionPitchMap, SectionChordMap, [ChordSpanF | PlanAcc], TotalSegs, ClimaxInfo).

% Pitch class to note name (copied from form.pi for local use)
pitch_class_name(0) = "C".
pitch_class_name(1) = "C#".
pitch_class_name(2) = "D".
pitch_class_name(3) = "Eb".
pitch_class_name(4) = "E".
pitch_class_name(5) = "F".
pitch_class_name(6) = "F#".
pitch_class_name(7) = "G".
pitch_class_name(8) = "Ab".
pitch_class_name(9) = "A".
pitch_class_name(10) = "Bb".
pitch_class_name(11) = "B".
pitch_class_name(N) = pitch_class_name(N mod 12).

% ==============================================================================
% SEGMENT GENERATION
% ==============================================================================

% Generate melodies for all segments and concatenate
generate_all_segments(Segments, KeyRoot) = AllNotes =>
    AllNotes = generate_segments_helper(Segments, KeyRoot, 1, 0, []).

generate_segments_helper([], _, _, _, Acc) = flatten(reverse(Acc)).
generate_segments_helper([Seg | Rest], KeyRoot, SegIndex, CurrentBar, Acc) = Result =>
    NumBars = get_segment_num_bars(Seg),
    Params = get_segment_params(Seg),

    % Generate melody for this segment (with fallback on failure)
    if Acc == [] then
        % First segment - no connection needed
        once(generate_segment_melody(Params, KeyRoot, NumBars, SegmentMelody))
    else
        % Connect to previous segment, with fallback to unconnected if fails
        PrevMelody = head(Acc),
        PrevLastPitch = last_pitch(PrevMelody),
        if once(generate_connected_segment_melody(Params, KeyRoot, NumBars, PrevLastPitch, SegmentMelody0)) then
            SegmentMelody = SegmentMelody0
        else
            % Fallback: generate without connection constraint
            once(generate_segment_melody(Params, KeyRoot, NumBars, SegmentMelody))
        end
    end,

    % Print after successful generation to avoid repeated output on backtracking
    printf("  Segment %2d: bars %3d-%3d, tempo=%3d, mode=%-12w%n",
    SegIndex, CurrentBar + 1, CurrentBar + NumBars,
    get_tempo(Params), get_mode(Params)),

    % Adjust timing to absolute bar positions
    TimedMelody = [adjust_note_bar(Note, CurrentBar) : Note in SegmentMelody],

    Result = generate_segments_helper(Rest, KeyRoot, SegIndex + 1, CurrentBar + NumBars, [TimedMelody | Acc]).

% ==============================================================================
% ACCOMPANIMENT GENERATION
% ==============================================================================

% Generate accompaniment from the chord plan the melody was solved against
% ChordPlan: list of $chord_span(StartBarOffset, NumBars, KeyRoot, Mode, Degrees)
% Genre = none means use default pattern; Pattern = none means disabled
generate_accompaniment_from_plan(MelodyNotes, ChordPlan, Genre, Pattern) = AccompNotes =>
    if MelodyNotes == [] ; ChordPlan == [] then
        AccompNotes = []
    elseif Pattern == none then
        AccompNotes = [],
        println("Accompaniment disabled")
    else
        println("Generating accompaniment..."),
        ChordProg = flatten([span_to_assignments(Span) : Span in ChordPlan]),
        AccompNotes = render_accompaniment(ChordProg, MelodyNotes, Genre, Pattern)
    end.

% Convert one chord_span into chord assignments at absolute bar positions
span_to_assignments(chord_span(StartBar, _NumBars, SpanKeyRoot, SpanMode, Degrees)) = Assignments =>
    CAs = chord_generator.degrees_to_chord_assignments(Degrees, SpanKeyRoot mod 12, SpanMode),
    Assignments = [offset_assignment(CA, StartBar) : CA in CAs].

% Shift a chord assignment's bar number by an offset
% (split bars are $chord_pair entries holding two assignments)
offset_assignment(chord_pair(CAa, CAb), Offset) = CA =>
    NewA = offset_assignment(CAa, Offset),
    NewB = offset_assignment(CAb, Offset),
    CA = $chord_pair(NewA, NewB).
offset_assignment(chord_assignment(Bar, Deg, Quality, RootPC, Bass), Offset) = CA =>
    NewBar = Bar + Offset,
    CA = $chord_assignment(NewBar, Deg, Quality, RootPC, Bass).

% Generate accompaniment for a melody without a chord plan (legacy path)
% Fits chords to the melody that was actually generated (harmonizer),
% instead of solving an unrelated progression that could clash with it.
% Genre = none means use default (block) pattern
% Pattern = none means disabled
generate_accompaniment_for_melody(MelodyNotes, KeyRoot, Segments, Genre, Pattern) = AccompNotes =>
    if MelodyNotes == [] then
        AccompNotes = []
    elseif Pattern == none then
        AccompNotes = [],
        println("Accompaniment disabled")
    else
        % Determine mode from first segment
        FirstParams = get_segment_params(Segments[1]),
        Mode = get_mode(FirstParams),

        % Total bars from melody notes
        MaxBar = max([Bar : $note(_, _, $time_pos(Bar, _, _), _, _) in MelodyNotes]),

        println("Generating accompaniment..."),
        GenreForChords = cond(Genre != none, Genre, classical_period),
        ChordProg = harmonizer.harmonize_melody(MelodyNotes, KeyRoot, Mode, GenreForChords, MaxBar),
        AccompNotes = render_accompaniment(ChordProg, MelodyNotes, Genre, Pattern)
    end.

% Render chord assignments into accompaniment notes with pattern selection
render_accompaniment(ChordProg, MelodyNotes, Genre, Pattern) = AccompNotes =>
    AvgVel = accompaniment.average_velocity(MelodyNotes),

    % Select pattern (auto = use genre default, explicit = use specified pattern)
    if Pattern == auto then
        GenreForPattern = cond(Genre != none, Genre, classical_period),
        AccompNotes0 = accompaniment.generate_accompaniment(ChordProg, GenreForPattern, AvgVel)
    else
        AccompNotes0 = accompaniment.generate_accompaniment(ChordProg, Pattern, Genre, AvgVel)
    end,

    % Light velocity humanization for accompaniment (micro-timing is applied
    % later on the merged melody+accompaniment stream so onsets stay aligned)
    AccompNotes = humanize.humanize_notes(AccompNotes0, 0.15),
    printf("  Generated %d accompaniment notes%n%n", length(AccompNotes)).

% Get accomp pattern preference from CLI preferences list
% Returns: explicit pattern name, 'auto' (use genre default), or 'none' (disabled)
get_accomp_preference(Preferences) = Pattern =>
    if member(accomp=P, Preferences) then
        Pattern = P
    else
        Pattern = auto  % Default: auto-select from genre
    end.

% Get ornament density from preferences (0.0 = no ornaments, 1.0 = maximum)
get_ornament_density(Preferences) = Density =>
    if find_first_key(Preferences, ornaments, OrnVal) then
        if OrnVal == off then
            Density = 0.0
        elseif number(OrnVal) then
            Density = OrnVal
        else
            Density = 0.5  % Default density when ornaments=on
        end
    else
        Density = 0.3  % Default: light ornamentation
    end.

% ==============================================================================
% EXPRESSION AND HUMANIZATION
% ==============================================================================

% Apply velocity curves segment-by-segment
% Each segment is treated as a phrase with its own dynamic curve
apply_segment_expression(AllNotes, Segments) = ExpressiveNotes =>
    % Build bar-to-segment map for velocity params lookup
    BarToParams = build_bar_params_map(Segments),
    % Group notes by segment (using bar ranges)
    SegmentBarRanges = get_segment_bar_ranges(Segments),
    ExpressiveNotes = apply_expression_by_segments(AllNotes, SegmentBarRanges, BarToParams).

% Build map from bar number to (VelBase, VelVar) for each segment
build_bar_params_map(Segments) = Map =>
    Map = build_bar_params_helper(Segments, 1, new_map()).

build_bar_params_helper([], _, Map) = Map.
build_bar_params_helper([Seg | Rest], CurrentBar, Map) = Result =>
    NumBars = get_segment_num_bars(Seg),
    Params = get_segment_params(Seg),
    VelBase = get_velocity_base(Params),
    VelVar = get_velocity_var(Params),
    foreach(B in CurrentBar..CurrentBar+NumBars-1)
        put(Map, B, (VelBase, VelVar))
    end,
    Result = build_bar_params_helper(Rest, CurrentBar + NumBars, Map).

% Get bar ranges for each segment: [(StartBar, EndBar), ...]
get_segment_bar_ranges(Segments) = Ranges =>
    Ranges = get_bar_ranges_helper(Segments, 1, []).

get_bar_ranges_helper([], _, Acc) = reverse(Acc).
get_bar_ranges_helper([Seg | Rest], CurrentBar, Acc) = Result =>
    NumBars = get_segment_num_bars(Seg),
    EndBar = CurrentBar + NumBars - 1,
    Result = get_bar_ranges_helper(Rest, CurrentBar + NumBars, [(CurrentBar, EndBar) | Acc]).

% Apply expression to notes grouped by segment bar ranges
apply_expression_by_segments(AllNotes, SegmentBarRanges, BarToParams) = ExpressiveNotes =>
    % Group notes into segments by bar
    SegmentedNotes = group_notes_by_segments(AllNotes, SegmentBarRanges),
    % Apply velocity curves to each segment
    ProcessedSegments = [apply_segment_curve(SegNotes, BarToParams) : SegNotes in SegmentedNotes],
    ExpressiveNotes = flatten(ProcessedSegments).

% Group notes into segments based on bar ranges
group_notes_by_segments(Notes, BarRanges) = Groups =>
    Groups = [segment_notes(Notes, Start, End) : (Start, End) in BarRanges].

segment_notes(Notes, StartBar, EndBar) = SegNotes =>
    SegNotes = [N : N in Notes, note_in_bar_range(N, StartBar, EndBar)].

note_in_bar_range(note(_, _, time_pos(Bar, _, _), _, _), StartBar, EndBar) =>
    Bar >= StartBar, Bar =< EndBar.

% Apply velocity curve to a single segment's notes
apply_segment_curve(SegNotes, BarToParams) = CurvedNotes =>
    if SegNotes == [] then
        CurvedNotes = []
    else
        % Get VelBase and VelVar from first note's bar
        FirstNote = head(SegNotes),
        FirstNote = $note(_, _, $time_pos(FirstBar, _, _), _, _),
        (VelBase, VelVar) = cond(BarToParams.has_key(FirstBar), BarToParams.get(FirstBar), (80, 15)),
        CurvedNotes = humanize.apply_velocity_curves(SegNotes, VelBase, VelVar)
    end.

% Adjust note's bar number to absolute position
adjust_note_bar(Note, BarOffset) = AdjustedNote =>
    Note = $note(Pitch, Duration, $time_pos(Bar, Beat, Sub), VoiceId, Vel),
    NewBar = Bar + BarOffset,
    AdjustedNote = $note(Pitch, Duration, $time_pos(NewBar, Beat, Sub), VoiceId, Vel).

% Collect tempo changes for each segment (default: ritardando on)
collect_tempo_changes(Segments) = collect_tempo_changes(Segments, []).

% Collect tempo changes with preferences (rit=off disables ritardando)
collect_tempo_changes(Segments, Preferences) = Changes =>
    if find_first_key(Preferences, rit, RitVal), RitVal == off then
        Changes = collect_tempo_simple(Segments, 1, [])
    else
        Changes = collect_tempo_with_rit(Segments, 1, [])
    end.

% Simple: one tempo per segment (original behavior)
collect_tempo_simple([], _, Acc) = reverse(Acc).
collect_tempo_simple([Seg | Rest], CurrentBar, Acc) = Result =>
    Params = get_segment_params(Seg),
    Tempo = get_tempo(Params),
    NumBars = get_segment_num_bars(Seg),
    Change = $tempo_change(CurrentBar, Tempo),
    Result = collect_tempo_simple(Rest, CurrentBar + NumBars, [Change | Acc]).

% With ritardando: adds cadential slowdown in the last bars of segments >=4
% bars. Only the FINAL segment gets the full 2-bar 20% ritardando; interior
% segments get a gentle 1-bar easing — a deep mid-piece rit followed by a
% jump to the next (often faster) segment tempo lurches audibly.
collect_tempo_with_rit([], _, Acc) = reverse(Acc).
collect_tempo_with_rit([Seg | Rest], CurrentBar, Acc) = Result =>
    Params = get_segment_params(Seg),
    Tempo = get_tempo(Params),
    NumBars = get_segment_num_bars(Seg),
    BaseChange = $tempo_change(CurrentBar, Tempo),
    if NumBars >= 4 then
        SectionEndBar = CurrentBar + NumBars - 1,
        if Rest == [] then
            RitChanges = temporal.cadential_ritardando(Tempo, SectionEndBar, 2, 0.8)
        else
            RitChanges = temporal.cadential_ritardando(Tempo, SectionEndBar, 1, 0.92)
        end,
        AllChanges = [BaseChange | RitChanges]
    else
        AllChanges = [BaseChange]
    end,
    Result = collect_tempo_with_rit(Rest, CurrentBar + NumBars, reverse(AllChanges) ++ Acc).

% ==============================================================================
% COMMAND LINE INTERFACE
% ==============================================================================
% Note: Picat 3.9 has a bug where arguments starting with '--' cause SIGSEGV
% We use simple argument style: 'from' instead of '--from'

% Parse command line arguments
main(Args) =>
    % Handle empty arguments
    if Args == [] then
        print_usage(),
        halt
    end,

    % Extract command and remaining options
    FirstArg = head(Args),
    RestArgs = tail(Args),

    % Handle special commands (with optional additional options)
    if FirstArg == "help" ; FirstArg == "-h" then
        print_usage(),
        halt
    elseif FirstArg == "moods" then
        print_all_presets(),
        halt
    elseif FirstArg == "genres" then
        print_all_genres(),
        halt
    elseif FirstArg == "demo" then
        % Parse additional options for demo (genre, accomp, randomness, etc.)
        ParsedOpts = parse_args(RestArgs),
        maybe_seed_rng(ParsedOpts),
        % Default 0.2: rand_val labeling varies output run-to-run without
        % weakening optimization; deterministic solves over-repeat 4-gram
        % patterns vs the masterpiece corpus (randomness=0.0 restores)
        Randomness = get_arg(ParsedOpts, randomness, 0.2),
        % Quality path by default; genre=none / rhythm=off restore legacy behavior
        Genre = get_arg(ParsedOpts, genre, classical_period),
        DemoOutput = get_arg(ParsedOpts, output, "session.json"),
        DemoCount = get_arg(ParsedOpts, count, 1),
        % All remaining options (accomp/rhythm/refine/meter/rit/key/tempo/...)
        % flow through the shared preference builder
        DemoPrefs = build_preferences(ParsedOpts),
        demo_with_prefs(Randomness, Genre, DemoPrefs, DemoOutput, DemoCount),
        halt
    elseif FirstArg == "path" then
        demo_path(),
        halt
    elseif FirstArg == "melody_demo" then
        run_melody_demo(),
        halt
    elseif FirstArg == "test" then
        run_quick_test(),
        halt
    elseif FirstArg == "violin" then
        % Violin mode: generate with violin-specific output
        ParsedOpts = parse_args(RestArgs),
        run_violin_companion(ParsedOpts),
        halt
    end,

    % Parse key=value arguments
    ParsedArgs = parse_args(Args),
    maybe_seed_rng(ParsedArgs),

    % Extract options
    Duration = get_arg(ParsedArgs, duration, 300),
    Output = get_arg(ParsedArgs, output, "session.json"),
    % Default 0.2: variety without weakening optimization (see demo branch)
    Randomness = get_arg(ParsedArgs, randomness, 0.2),

    % Handle VA coordinates or presets - at least one of from/from_va and to/to_va required
    FromVA = get_arg(ParsedArgs, from_va, none),
    ToVA = get_arg(ParsedArgs, to_va, none),
    StartPreset = get_arg(ParsedArgs, from, none),
    EndPreset = get_arg(ParsedArgs, to, none),

    % Validate: require either preset or VA coordinates for start mood
    if FromVA == none, StartPreset == none then
        println("Error: Missing start mood. Provide 'from=PRESET' or 'from_va=V,A'"),
        println("Run 'picat companion.pi moods' to see available presets."),
        halt
    end,
    StartMood = cond(FromVA != none, parse_va(FromVA), mood_preset(StartPreset)),

    % Validate: require either preset or VA coordinates for end mood
    if ToVA == none, EndPreset == none then
        println("Error: Missing end mood. Provide 'to=PRESET' or 'to_va=V,A'"),
        println("Run 'picat companion.pi moods' to see available presets."),
        halt
    end,
    EndMood = cond(ToVA != none, parse_va(ToVA), mood_preset(EndPreset)),

    % Check for form-based generation
    FormType = get_arg(ParsedArgs, form, none),
    % Quality path by default; genre=none restores the legacy basic generator
    Genre = get_arg(ParsedArgs, genre, classical_period),
    Count = get_arg(ParsedArgs, count, 1),
    Preferences = build_preferences(ParsedArgs),

    % Dispatch to single or multiple output generation
    if Count > 1 then
        % Generate N different outputs
        run_companion_multiple(StartMood, EndMood, Duration, Output, Randomness, Count, Genre, FormType, Preferences)
    elseif FormType != none, FormType != through then
        % Form-based generation (optionally with genre)
        run_companion_with_form(StartMood, EndMood, Duration, Output, Randomness, FormType, Genre, Preferences)
    elseif Genre != none then
        % Genre-based generation (no form)
        run_companion_with_genre(StartMood, EndMood, Duration, Output, Randomness, Genre, Preferences)
    else
        % Standard generation
        run_companion(StartMood, EndMood, Duration, Output, Randomness, Preferences)
    end.

% Parse meter string like "3/4", "6/8", "3/8", "2/2"
parse_meter(MeterStr) = Meter =>
    Parts = split(MeterStr, "/"),
    if length(Parts) == 2 then
        Beats = to_integer(Parts[1]),
        Unit = to_integer(Parts[2]),
        Meter = $meter(Beats, Unit)
    else
        printf("Warning: Invalid meter '%s', using 4/4%n", MeterStr),
        Meter = $meter(4, 4)
    end.

% Parse VA coordinate string like "-0.7,-0.3"
parse_va(VAString) = Mood =>
    Parts = split(VAString, ","),
    if length(Parts) == 2 then
        V = to_float(Parts[1]),
        A = to_float(Parts[2]),
        Mood = $mood(V, A)
    else
        throw($error(invalid_va_format, VAString))
    end.

% Parse command line arguments (key=value format)
parse_args(Args) = ParsedMap =>
    ParsedMap = parse_args_helper(Args, new_map()).

parse_args_helper([], Map) = Map.
parse_args_helper([Arg | Rest], Map) = Result =>
    % Parse key=value format
    Parts = split(Arg, "="),
    if length(Parts) >= 2 then
        Key = Parts[1],
        Value = join_rest(Parts, 2),
        Map2 = set_arg(Map, Key, Value),
        Result = parse_args_helper(Rest, Map2)
    else
        printf("Warning: Unknown argument '%s' (use key=value format)%n", Arg),
        Result = parse_args_helper(Rest, Map)
    end.

% Join parts from index onwards (in case value contains '=')
join_rest(Parts, StartIdx) = Result =>
    if StartIdx > length(Parts) then
        Result = ""
    else
        Result = join([Parts[I] : I in StartIdx..length(Parts)], "=")
    end.

% Set argument in map based on key (put modifies in-place)
set_arg(Map, "from", Value) = Map =>
    Map.put(from, to_atom(Value)).
set_arg(Map, "to", Value) = Map =>
    Map.put(to, to_atom(Value)).
set_arg(Map, "from_va", Value) = Map =>
    Map.put(from_va, Value).
set_arg(Map, "to_va", Value) = Map =>
    Map.put(to_va, Value).
set_arg(Map, "duration", Value) = Map =>
    Map.put(duration, to_integer(Value)).
set_arg(Map, "output", Value) = Map =>
    Map.put(output, Value).
set_arg(Map, "randomness", Value) = Map =>
    Map.put(randomness, to_float(Value)).
set_arg(Map, "random", Value) = Map =>
    Map.put(randomness, to_float(Value)).
set_arg(Map, "genre", Value) = Map =>
    Map.put(genre, to_atom(Value)).
set_arg(Map, "form", Value) = Map =>
    Map.put(form, form.parse_form_type(Value)).
set_arg(Map, "disable", Value) = Map =>
    % Disable a constraint: disable=constraint_id
    Existing = Map.get(disable, []),
    Map.put(disable, Existing ++ [to_atom(Value)]).
set_arg(Map, "intensity", Value) = Map =>
    Map.put(intensity, to_atom(Value)).
set_arg(Map, "accomp", Value) = Map =>
    Map.put(accomp, to_atom(Value)).
set_arg(Map, "contrast", Value) = Map =>
    Map.put(contrast, to_atom(Value)).
set_arg(Map, "rhythm", Value) = Map =>
    Map.put(rhythm, to_atom(Value)).
set_arg(Map, "count", Value) = Map =>
    Map.put(count, to_integer(Value)).
set_arg(Map, "refine", Value) = Map =>
    if Value == "on" then
        Map.put(refine, 3)
    else
        Map.put(refine, to_integer(Value))
    end.
set_arg(Map, "refine_piece", Value) = Map =>
    if Value == "on" then
        Map.put(refine_piece, 3)
    else
        Map.put(refine_piece, to_integer(Value))
    end.
set_arg(Map, "meter", Value) = Map =>
    Map.put(meter, parse_meter(Value)).
set_arg(Map, "rit", Value) = Map =>
    Map.put(rit, to_atom(Value)).
set_arg(Map, "ornaments", Value) = Map =>
    if Value == "off" then
        Map.put(ornaments, off)
    elseif Value == "on" then
        Map.put(ornaments, on)
    else
        Map.put(ornaments, to_float(Value))
    end.
set_arg(Map, "key", Value) = Map =>
    % Raw lowercased string; parsed by parse_key in build_preferences
    Map.put(key, to_lowercase(Value)).
set_arg(Map, "tempo", Value) = Map =>
    Map.put(tempo, to_integer(Value)).
set_arg(Map, "seed", Value) = Map =>
    Map.put(seed, to_integer(Value)).
set_arg(Map, "instrument", Value) = Map =>
    Map.put(melody_instrument, to_integer(Value)).
set_arg(Map, "accomp_instrument", Value) = Map =>
    Map.put(accomp_instrument, to_integer(Value)).
set_arg(Map, Key, Value) = Map =>
    % Check for weight:constraint=value pattern
    if append("weight:", ConstraintStr, Key) then
        Constraint = to_atom(ConstraintStr),
        Weight = to_integer(Value),
        Existing = Map.get(weights, []),
        Map.put(weights, Existing ++ [(Constraint, Weight)])
    else
        printf("Warning: Unknown option '%s'%n", Key)
    end.

% Get argument with default
get_arg(Map, Key, Default) = Value =>
    if Map.has_key(Key) then
        Value = Map.get(Key)
    else
        Value = Default
    end.

% Convert string to atom
to_atom(S) = A =>
    A = to_lowercase(S).parse_term().

% Helper: join list with separator
join([], _) = "".
join([X], _) = X.
join([X|Rest], Sep) = X ++ Sep ++ join(Rest, Sep).

% Helper: find first Key=Value in a list of Key=Value pairs
% Returns true and binds Value if found, false otherwise
find_first_key([], _Key, _Value) => fail.
find_first_key([K=V|_Rest], Key, Value) ?=> K == Key, Value = V.
find_first_key([_|Rest], Key, Value) => find_first_key(Rest, Key, Value).

% ==============================================================================
% ARTIST MUSICAL OVERRIDES (key= / tempo= / seed=)
% ==============================================================================

% Seed the RNG once per process if seed= was given (reproducible takes).
% Reproducibility is best-effort: the anytime optimizer keeps the best
% solution found within a wall-clock budget, so heavy machine load can
% still change which solution wins.
maybe_seed_rng(ParsedArgs) =>
    SeedVal = get_arg(ParsedArgs, seed, none),
    if SeedVal != none then
        printf("Seed: %d (reproducible mode)%n", SeedVal),
        rng.seed_rng(SeedVal)
    end.

% Key root from preferences (default: middle C)
get_key_root_from_preferences(Preferences) = KeyRoot =>
    if find_first_key(Preferences, key_root, KR) then
        KeyRoot = KR
    else
        KeyRoot = 60
    end.

% Apply force_tempo/force_mode preferences to planned segments.
% RecomputeBars: true for free-form paths (bar counts follow the tempo);
% false for form mode (bar counts are locked to sections).
apply_musical_overrides(Segments, Preferences, RecomputeBars) = NewSegments =>
    if find_first_key(Preferences, force_tempo, FT) then TempoO = FT else TempoO = none end,
    if find_first_key(Preferences, force_mode, FM) then ModeO = FM else ModeO = none end,
    if TempoO != none then printf("  Tempo: %d BPM (fixed)%n", TempoO) end,
    if ModeO != none then printf("  Mode: %w (fixed)%n", ModeO) end,
    NewSegments = transition.apply_param_overrides(Segments, TempoO, ModeO, RecomputeBars).

% Parse a key name like "d_minor", "eb", "f#_dorian", "bb_major" into
% (RootMidi, ModeOrNone). Roots land within a fourth of middle C so the
% melody register stays comparable across keys. Returns (none, none) with
% a warning for unknown tonics.
parse_key(KeyStr) = (RootMidi, Mode) =>
    Parts = split(KeyStr, "_"),
    TonicStr = head(Parts),
    PC = tonic_pitch_class(TonicStr),
    if PC == none then
        printf("Warning: Unknown key '%s' (expected e.g. key=d_minor, key=eb, key=f#_dorian). Ignoring.%n", KeyStr),
        RootMidi = none,
        Mode = none
    else
        % Keys C..F# sit above middle C, G..B below (max distance a tritone)
        if PC <= 6 then RootMidi = 60 + PC else RootMidi = 48 + PC end,
        if length(Parts) >= 2 then
            ModeStr = join([Parts[I] : I in 2..length(Parts)], "_"),
            Mode0 = parse_mode_name(ModeStr),
            if Mode0 == none then
                printf("Warning: Unknown mode '%s' in key '%s' — using mood-driven mode.%n", ModeStr, KeyStr),
                Mode = none
            else
                Mode = Mode0
            end
        else
            Mode = none
        end
    end.

% Tonic name -> pitch class (accepts sharps as c#/cs and flats as db)
tonic_pitch_class("c")  = 0.
tonic_pitch_class("c#") = 1.
tonic_pitch_class("cs") = 1.
tonic_pitch_class("db") = 1.
tonic_pitch_class("d")  = 2.
tonic_pitch_class("d#") = 3.
tonic_pitch_class("ds") = 3.
tonic_pitch_class("eb") = 3.
tonic_pitch_class("e")  = 4.
tonic_pitch_class("f")  = 5.
tonic_pitch_class("f#") = 6.
tonic_pitch_class("fs") = 6.
tonic_pitch_class("gb") = 6.
tonic_pitch_class("g")  = 7.
tonic_pitch_class("g#") = 8.
tonic_pitch_class("gs") = 8.
tonic_pitch_class("ab") = 8.
tonic_pitch_class("a")  = 9.
tonic_pitch_class("a#") = 10.
tonic_pitch_class("as") = 10.
tonic_pitch_class("bb") = 10.
tonic_pitch_class("b")  = 11.
tonic_pitch_class(_)    = none.

% Mode name string -> scale_utils mode atom ("minor" = natural minor)
parse_mode_name(S) = lookup_mode_name(mode_name_table(), S).

mode_name_table() = [
    ("major", major), ("minor", natural_minor),
    ("natural_minor", natural_minor), ("harmonic_minor", harmonic_minor),
    ("melodic_minor", melodic_minor), ("dorian", dorian),
    ("phrygian", phrygian), ("lydian", lydian),
    ("mixolydian", mixolydian), ("aeolian", aeolian),
    ("ionian", ionian), ("locrian", locrian)].

lookup_mode_name([], _) = none.
lookup_mode_name([(Name, Atom) | Rest], S) = Mode =>
    if Name == S then
        Mode = Atom
    else
        Mode = lookup_mode_name(Rest, S)
    end.

% Human-readable key name, e.g. "D minor", "F# dorian"
key_name_string(KeyRoot, Mode) = Name =>
    NoteNames = ["C", "C#", "D", "Eb", "E", "F", "F#", "G", "Ab", "A", "Bb", "B"],
    NN = NoteNames[(KeyRoot mod 12) + 1],
    if Mode == natural_minor ; Mode == minor ; Mode == aeolian then
        MStr = "minor"
    elseif Mode == major ; Mode == ionian then
        MStr = "major"
    else
        MStr = to_fstring("%w", Mode)
    end,
    Name = NN ++ " " ++ MStr.

% Extra metadata pairs for the JSON export: key/mode/tempo/genre/mood info
% used by the MusicXML exporter, audio renderer, and the piece library.
build_export_metadata(KeyRoot, Segments, Genre, StartMood, EndMood, Preferences) = Meta =>
    if Segments != [] then
        FirstParams = get_segment_params(head(Segments)),
        Mode = get_mode(FirstParams),
        BaseTempo = get_tempo(FirstParams)
    else
        Mode = major,
        BaseTempo = 120
    end,
    % Extract instrument assignments: CLI args override genre defaults
    if find_first_key(Preferences, melody_instrument, MelodyOverride) then
        MelodyInst = MelodyOverride
    else if Genre != none, genre_profiles.genre_exists(Genre) then
        MelodyInst = genre_profiles.get_param(Genre, melody_instrument, 0)
    else
        MelodyInst = 0
    end end,
    if find_first_key(Preferences, accomp_instrument, AccompOverride) then
        AccompInst = AccompOverride
    else if Genre != none, genre_profiles.genre_exists(Genre) then
        AccompInst = genre_profiles.get_param(Genre, accomp_instrument, 0)
    else
        AccompInst = 0
    end end,
    Meta0 = [(key_root, KeyRoot), (mode, Mode),
             (key_name, key_name_string(KeyRoot, Mode)),
             (base_tempo, BaseTempo), (genre, Genre),
             (melody_instrument, MelodyInst), (accomp_instrument, AccompInst),
             (from_valence, get_valence(StartMood)),
             (from_arousal, get_arousal(StartMood)),
             (to_valence, get_valence(EndMood)),
             (to_arousal, get_arousal(EndMood))],
    if find_first_key(Preferences, seed, SeedM) then
        Meta = Meta0 ++ [(seed, SeedM)]
    else
        Meta = Meta0
    end.

% Extract meter from preferences list, defaulting to 4/4
get_meter_from_preferences(Preferences) = Meter =>
    if find_first_key(Preferences, meter, M) then
        Meter = M
    else
        Meter = $meter(4, 4)
    end.

