    println("After generating the JSON file, run:"),
    println("  python scripts/midi_writer.py session.json session.mid").

% Build preferences list from parsed CLI arguments
build_preferences(ParsedArgs) = Preferences =>
    Prefs = [],
    % Add disabled constraints
    Disabled = get_arg(ParsedArgs, disable, []),
    foreach(D in Disabled)
        Prefs := Prefs ++ [disable=D]
    end,
    % Add weight overrides (using weight_override(id, weight) structure)
    Weights = get_arg(ParsedArgs, weights, []),
    foreach((C, W) in Weights)
        Prefs := Prefs ++ [$weight_override(C, W)]
    end,
    % Add intensity
    Intensity = get_arg(ParsedArgs, intensity, standard),
    Prefs := Prefs ++ [intensity=Intensity],
    % Add accompaniment pattern
    Accomp = get_arg(ParsedArgs, accomp, none),
    if Accomp != none then
        Prefs := Prefs ++ [accomp=Accomp]
    end,
    % Add rhythm mode (on by default; rhythm=off gives uniform durations)
    Rhythm = get_arg(ParsedArgs, rhythm, on),
    if Rhythm == on then
        Prefs := Prefs ++ [rhythm=on]
    end,
    % Add refinement rounds
    Refine = get_arg(ParsedArgs, refine, 1),
    if Refine > 1 then
        Prefs := Prefs ++ [refine=Refine]
    end,
    RefinePiece = get_arg(ParsedArgs, refine_piece, 1),
    if RefinePiece > 1 then
        Prefs := Prefs ++ [refine_piece=RefinePiece]
    end,
    % Add meter (time signature)
    MeterVal = get_arg(ParsedArgs, meter, none),
    if MeterVal != none then
        Prefs := Prefs ++ [meter=MeterVal]
    end,
    % Add ritardando preference
    RitVal = get_arg(ParsedArgs, rit, on),
    if RitVal == off then
        Prefs := Prefs ++ [rit=off]
    end,
    % Add contrast preference for form sections
    Contrast = get_arg(ParsedArgs, contrast, auto),
    if Contrast != auto then
        Prefs := Prefs ++ [contrast=Contrast]
    end,
    % Add ornaments preference
    OrnVal = get_arg(ParsedArgs, ornaments, none),
    if OrnVal != none then
        Prefs := Prefs ++ [ornaments=OrnVal]
    end,
    % Add key override (key=d_minor -> key_root + force_mode)
    KeyVal = get_arg(ParsedArgs, key, none),
    if KeyVal != none, KeyVal != "auto" then
        (KRoot, KMode) = parse_key(KeyVal),
        if KRoot != none then
            Prefs := Prefs ++ [key_root=KRoot]
        end,
        if KMode != none then
            Prefs := Prefs ++ [force_mode=KMode]
        end
    end,
    % Add tempo override (fixed BPM for the whole piece)
    TempoVal = get_arg(ParsedArgs, tempo, none),
    if TempoVal != none then
        if TempoVal >= 40, TempoVal =< 220 then
            Prefs := Prefs ++ [force_tempo=TempoVal]
        else
            printf("Warning: tempo=%d out of range 40..220, ignoring%n", TempoVal)
        end
    end,
    % Record seed (consumed at startup by maybe_seed_rng) for metadata
    SeedPref = get_arg(ParsedArgs, seed, none),
    if SeedPref != none then
        Prefs := Prefs ++ [seed=SeedPref]
    end,
    % Add instrument overrides (GM program numbers)
    MelodyInst = get_arg(ParsedArgs, melody_instrument, none),
    if MelodyInst != none, MelodyInst >= 0, MelodyInst =< 127 then
        Prefs := Prefs ++ [melody_instrument=MelodyInst]
    end,
    AccompInst = get_arg(ParsedArgs, accomp_instrument, none),
    if AccompInst != none, AccompInst >= 0, AccompInst =< 127 then
        Prefs := Prefs ++ [accomp_instrument=AccompInst]
    end,
    Preferences = Prefs.

% Print all available genres
print_all_genres() =>
    println("Available genres:"),
    nl,
    foreach(Genre in genre_profiles.all_genres())
        Desc = genre_profiles.genre_description(Genre),
        Hard = genre_profiles.hard_constraints(Genre),
        Soft = genre_profiles.soft_constraints(Genre),
        printf("  %w%n", Genre),
        printf("    %s%n", Desc),
        printf("    Hard: %d constraints, Soft: %d constraints%n", length(Hard), length(Soft)),
        nl
    end.

% ==============================================================================
% DEMO AND TESTING
% ==============================================================================

% Quick demo with short duration
demo() =>
    run_companion_presets(sad_depressed, energized, 60, "session.json").

% Quick demo with randomness
demo_with_randomness(Randomness) =>
    run_companion_presets(sad_depressed, energized, 60, "session.json", Randomness).

% Quick demo with genre, accompaniment, rhythm, refinement, meter, and rit options
demo_with_options(Randomness, Genre, Accomp, Rhythm, Refine, RefinePiece, MeterOpt, RitOpt) =>
    demo_with_options(Randomness, Genre, Accomp, Rhythm, Refine, RefinePiece, MeterOpt, RitOpt, "session.json", 1).

demo_with_options(Randomness, Genre, Accomp, Rhythm, Refine, RefinePiece, MeterOpt, RitOpt, OutputPath, Count) =>
    % Build preferences list
    Prefs = cond(Accomp != auto, [accomp=Accomp], []),
    if Rhythm == on then
        Prefs := Prefs ++ [rhythm=on]
    end,
    if Refine > 1 then
        Prefs := Prefs ++ [refine=Refine]
    end,
    if RefinePiece > 1 then
        Prefs := Prefs ++ [refine_piece=RefinePiece]
    end,
    if MeterOpt != none then
        Prefs := Prefs ++ [meter=MeterOpt]
    end,
    if RitOpt == off then
        Prefs := Prefs ++ [rit=off]
    end,
    demo_with_prefs(Randomness, Genre, Prefs, OutputPath, Count).

% Demo driver over an already-built preferences list (the main demo branch
% builds it with build_preferences, so key=/tempo=/seed=/ornaments= all work)
demo_with_prefs(Randomness, Genre, Prefs, OutputPath, Count) =>
    % count=N routes through the multi-variation generator (numbered outputs)
    if Count > 1 then
        run_companion_multiple(mood_preset(sad_depressed), mood_preset(energized), 60,
                               OutputPath, Randomness, Count, Genre, none, Prefs)
    elseif Genre != none then
        run_companion_with_genre(mood_preset(sad_depressed), mood_preset(energized), 60, OutputPath, Randomness, Genre, Prefs)
    else
        run_companion(mood_preset(sad_depressed), mood_preset(energized), 60, OutputPath, Randomness, Prefs)
    end.

% Demo showing transition path only (no generation)
demo_path() =>
    StartMood = mood_preset(anxious),
    EndMood = mood_preset(calm_peaceful),
    Segments = plan_transition(StartMood, EndMood, 300, ease_in_out),
    print_transition_summary(StartMood, EndMood, Segments),
    nl,
    print_transition_path(Segments).

% Test mood mapping
test_mood_mapping() =>
    println("Testing mood-to-music mapping:"),
    nl,
    foreach(Preset in [sad_depressed, anxious, calm_peaceful, energized, happy])
        M = mood_preset(Preset),
        P = mood_to_params(M),
        printf("%-15w: tempo=%3d, mode=%-12w, density=%d, velocity=%d%n",
        Preset, get_tempo(P), get_mode(P), get_note_density(P), get_velocity_base(P))
    end.

