    Segments = plan_transition(StartMood, EndMood, 300, ease_in_out),
    print_transition_summary(StartMood, EndMood, Segments),
    nl,
    print_transition_path(Segments).

% Test mood mapping
test_mood_mapping() =>
    println("Testing mood-to-music mapping:"),
    nl,
    foreach(Preset in [sad_depressed, anxious, calm_peaceful, energized, happy])
        M = mood_preset(Preset),
        P = mood_to_params(M),
        printf("%-15w: tempo=%3d, mode=%-12w, density=%d, velocity=%d%n",
        Preset, get_tempo(P), get_mode(P), get_note_density(P), get_velocity_base(P))
    end.

