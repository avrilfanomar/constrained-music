    println("                   on: melodies with mixed note durations"),
    println("                   off: uniform durations (legacy behavior)"),
    println("  meter=N/M        Time signature (default: 4/4)"),
    println("                   Supported: 3/4, 6/8, 3/8, 2/2, 2/4"),
    println("  rit=off          Disable cadential ritardando (default: on)"),
    println("                   When on, last 2 bars of segments >= 4 bars slow to 80% tempo"),
    nl,
    println("Musical Options (artist overrides; default: derived from mood):"),
    println("  key=NAME         Fix the key, e.g. key=d_minor, key=eb, key=f#_dorian"),
    println("                   Tonic: c, c#/db, d, ..., b. Mode (optional): major, minor,"),
    println("                   harmonic_minor, melodic_minor, dorian, phrygian, lydian,"),
    println("                   mixolydian, aeolian, locrian. Tonic alone keeps mood-driven mode."),
    println("  tempo=BPM        Fix the tempo for the whole piece (40-220);"),
    println("                   cadential ritardando still applies within segments"),
    println("  seed=N           Reproducible generation (same seed = same piece, best effort:"),
    println("                   heavy machine load can change anytime-optimizer results)"),
    nl,
    println("Genre Options (for weighted constraint optimization):"),
    println("  genre=GENRE      Genre-based constraint selection (default: classical_period)"),
    println("                   (classical_period, baroque, romantic, traditional_jazz,"),
    println("                   folk_traditional, contemporary, sacred_chant, children_songs,"),
    println("                   minimalist, modal, blues)"),
    println("                   genre=none disables genre constraints (legacy generator)"),
    println("  intensity=LEVEL  Constraint intensity: light, standard, strict"),
    println("  disable=ID       Disable a specific constraint (can use multiple times)"),
    println("  weight:ID=N      Override constraint weight (0-100)"),
    nl,
    println("Examples:"),
    println("  picat companion.pi demo"),
    println("  picat companion.pi from=sad_depressed to=energized duration=300"),
    println("  picat companion.pi from_va=-0.7,-0.3 to_va=0.5,0.8 duration=600"),
    println("  picat companion.pi from=calm_peaceful to=energized randomness=0.5"),
    println("  picat companion.pi from=calm_peaceful to=energized count=5 randomness=0.3"),
