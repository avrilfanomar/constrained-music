    nl,
    println("Form Options (for structured composition):"),
    println("  form=TYPE        Use form structure for composition"),
    println("                   (binary, ternary, rondo, through)"),
    println("                   binary:  AB - two contrasting sections"),
    println("                   ternary: ABA - statement, contrast, return"),
    println("                   rondo:   ABACA - recurring refrain with episodes"),
    println("                   through: no repetition (free form)"),
    println("  contrast=MODE    Section contrast mode: auto (default), off"),
    println("                   auto: B/C sections use contrasting genre"),
    println("                   off: all sections use the same genre"),
    nl,
    println("Refinement Options:"),
    println("  refine=N         Per-segment refinement: generate each segment N times,"),
    println("                   keep best (default: 1 = no refinement, 'on' = 3)"),
    println("  refine_piece=N   Per-piece refinement: generate entire piece N times,"),
    println("                   keep best (default: 1 = no refinement, 'on' = 3)"),
    nl,
    println("Rhythm & Tempo Options:"),
