% test_constraint_validation.pi - Unified constraint checking for famous pieces validation
% Provides a dispatcher to check constraints against static pitch data

module test_constraint_validation.

import cp.
import music_constraints.
import advanced.
import soft_constraints.
import piece_utils.
import pieces_folk.
import pieces_bach.
import pieces_mozart.
import pieces_beethoven.
import scale_utils.

% ==============================================================================
% HARD CONSTRAINT CHECKERS (Boolean: pass/fail)
% ==============================================================================
% These check if a constraint is satisfied on static data (not CP variables)

% Check if there are no parallel fifths between two voices
check_no_parallel_fifths(Voice1, Voice2) =>
    Len = length(Voice1),
    foreach(I in 1..Len-1)
        Int1 = abs(Voice1[I] - Voice2[I]) mod 12,
        Int2 = abs(Voice1[I+1] - Voice2[I+1]) mod 12,
        M1 = Voice1[I+1] - Voice1[I],
        M2 = Voice2[I+1] - Voice2[I],
        % Fail if both intervals are fifths and motion is parallel
        not (Int1 == 7, Int2 == 7, M1 * M2 > 0)
    end.

% Check if there are no parallel octaves between two voices
check_no_parallel_octaves(Voice1, Voice2) =>
    Len = length(Voice1),
    foreach(I in 1..Len-1)
        Int1 = abs(Voice1[I] - Voice2[I]) mod 12,
        Int2 = abs(Voice1[I+1] - Voice2[I+1]) mod 12,
        M1 = Voice1[I+1] - Voice1[I],
        M2 = Voice2[I+1] - Voice2[I],
        not (Int1 == 0, Int2 == 0, M1 * M2 > 0)
    end.

% Check no voice crossing (higher voice stays above lower)
check_no_voice_crossing(HigherVoice, LowerVoice) =>
    foreach(I in 1..length(HigherVoice))
        HigherVoice[I] >= LowerVoice[I]
    end.

% Check leading tone resolution
check_leading_tone_resolution(Pitches, KeyRoot) =>
    LeadingTone = (KeyRoot + 11) mod 12,
    Tonic = KeyRoot mod 12,
    Len = length(Pitches),
    foreach(I in 1..Len-1)
        NotePC = Pitches[I] mod 12,
        NextPC = Pitches[I+1] mod 12,
        % If on leading tone, next must be tonic or stay on leading tone
        if NotePC == LeadingTone then
            (NextPC == Tonic ; NextPC == LeadingTone)
        end
    end.

% Check ends on tonic
check_ends_on_tonic(Pitches, KeyRoot) =>
    LastPC = Pitches[length(Pitches)] mod 12,
    TonicPC = KeyRoot mod 12,
    LastPC == TonicPC.

% Check ends on stable tone (1, 3, or 5 of scale)
check_phrase_ends_stable(Pitches, KeyRoot) =>
    LastInterval = (Pitches[length(Pitches)] - KeyRoot) mod 12,
    member(LastInterval, [0, 4, 7]).  % Root, major third, fifth

% Check no 3-semitone intervals (overly broad - catches minor thirds too)
% Renamed from check_no_augmented_seconds for clarity
check_no_three_semitone_intervals(Pitches) =>
    Len = length(Pitches),
    foreach(I in 1..Len-1)
        Interval = abs(Pitches[I+1] - Pitches[I]),
        Interval != 3
    end.

% Legacy alias for backward compatibility
check_no_augmented_seconds(Pitches) =>
    check_no_three_semitone_intervals(Pitches).

% Context-aware augmented second check
% Only forbids 3-semitone intervals between ADJACENT scale degrees
% Parameters:
%   Pitches: list of MIDI pitches
%   KeyRoot: root of the scale (0-127)
%   Mode: scale mode atom (e.g., harmonic_minor, major)
check_no_augmented_seconds_in_scale(Pitches, KeyRoot, Mode) =>
    Intervals = scale_utils.mode_intervals(Mode),
    RootClass = KeyRoot mod 12,
    Len = length(Pitches),
    foreach(I in 1..Len-1)
        Interval = abs(Pitches[I+1] - Pitches[I]),
        if Interval == 3 then
            % 3 semitones - check if it's between adjacent scale degrees
            not is_adjacent_degrees(Pitches[I], Pitches[I+1], RootClass, Intervals)
        end
    end.

% Helper: check if two notes are on adjacent scale degrees
is_adjacent_degrees(Note1, Note2, RootClass, Intervals) =>
    PC1 = (Note1 - RootClass + 120) mod 12,
    PC2 = (Note2 - RootClass + 120) mod 12,
    Deg1 = find_degree(PC1, Intervals),
    Deg2 = find_degree(PC2, Intervals),
    Deg1 > 0, Deg2 > 0,  % Both must be in scale
    ScaleSize = length(Intervals),
    DegDiff = abs(Deg1 - Deg2),
    (DegDiff == 1 ; DegDiff == ScaleSize - 1).  % Adjacent including wrap-around

% Find scale degree (1-indexed), 0 if not in scale
find_degree(PitchClass, Intervals) = Degree =>
    Degree = 0,
    foreach(I in 1..length(Intervals))
        if Intervals[I] == PitchClass then
            Degree := I
        end
    end.

% Check no tritone outline (across 3 consecutive notes)
check_no_tritone_outline(Pitches) =>
    Len = length(Pitches),
    foreach(I in 1..Len-2)
        PC1 = Pitches[I] mod 12,
        PC3 = Pitches[I+2] mod 12,
        Outline = abs(PC3 - PC1),
        Outline != 6, (12 - Outline) != 6  % 6 semitones = tritone
    end.

% Check max range constraint
check_max_range(Pitches, MaxRange) =>
    Range = max(Pitches) - min(Pitches),
    Range =< MaxRange.

% Check min range constraint
check_min_range(Pitches, MinRange) =>
    Range = max(Pitches) - min(Pitches),
    Range >= MinRange.

% ==============================================================================
% SOFT CONSTRAINT SCORERS (Return violation count)
% ==============================================================================
% These return the number of violations, suitable for comparison/baseline

% Score leap recovery violations
score_leap_recovery(Pitches) = Count =>
    Len = length(Pitches),
    if Len < 3 then
        Count = 0
    else
        Count = length([I : I in 1..Len-2,
            abs(Pitches[I+1] - Pitches[I]) >= 5,
            (Pitches[I+1] - Pitches[I]) * (Pitches[I+2] - Pitches[I+1]) >= 0
        ])
    end.

% Score mostly stepwise violations (count non-stepwise intervals)
score_mostly_stepwise(Pitches, MinPercent) = Violations =>
    Len = length(Pitches),
    if Len < 2 then
        Violations = 0
    else
        NumIntervals = Len - 1,
        StepCount = length([I : I in 1..NumIntervals, abs(Pitches[I+1] - Pitches[I]) =< 2]),
        MinSteps = (NumIntervals * MinPercent) // 100,
        Shortfall = MinSteps - StepCount,
        Violations = max(0, Shortfall)
    end.

% Score consecutive same-direction leaps
score_consecutive_leaps(Pitches) = Count =>
    Len = length(Pitches),
    if Len < 3 then
        Count = 0
    else
        Count = length([I : I in 1..Len-2,
            abs(Pitches[I+1] - Pitches[I]) >= 3,
            abs(Pitches[I+2] - Pitches[I+1]) >= 3,
            (Pitches[I+1] - Pitches[I]) * (Pitches[I+2] - Pitches[I+1]) > 0
        ])
    end.

% Score single climax (0 = good, 1-2 = violations)
score_single_climax(Pitches) = Violations =>
    Len = length(Pitches),
    if Len < 3 then
        Violations = 0
    else
        MaxPitch = max(Pitches),
        ClimaxPositions = [I : I in 1..Len, Pitches[I] == MaxPitch],
        NumClimax = length(ClimaxPositions),
        ThirdStart = Len // 3 + 1,
        ThirdEnd = 2 * Len // 3,
        InMiddle = length([P : P in ClimaxPositions, P >= ThirdStart, P =< ThirdEnd]),
        NotSingle = cond(NumClimax != 1, 1, 0),
        NotInMiddle = cond(InMiddle == 0, 1, 0),
        Violations = NotSingle + NotInMiddle
    end.

% Score balanced motion (difference between ascending/descending)
score_balanced_motion(Pitches, TolerancePercent) = Violations =>
    Len = length(Pitches),
    if Len < 2 then
        Violations = 0
    else
        NumIntervals = Len - 1,
        AscCount = length([I : I in 1..NumIntervals, Pitches[I+1] > Pitches[I]]),
        DescCount = length([I : I in 1..NumIntervals, Pitches[I+1] < Pitches[I]]),
        Tolerance = max(1, (NumIntervals * TolerancePercent) // 100),
        Excess = abs(AscCount - DescCount) - Tolerance,
        Violations = max(0, Excess)
    end.

% Score arch contour violations
score_arch_contour(Pitches) = Violations =>
    Len = length(Pitches),
    if Len < 4 then
        Violations = 0
    else
        MidPoint = Len // 2,
        Count = 0,
        foreach(I in 1..Len-1)
            Interval = Pitches[I+1] - Pitches[I],
            if I =< MidPoint then
                % First half: violation if descending > 2
                if Interval < -2 then Count := Count + 1 end
            else
                % Second half: violation if ascending > 2
                if Interval > 2 then Count := Count + 1 end
            end
        end,
        Violations = Count
    end.

% Score leading tone emphasis (count excess leading tones)
score_leading_tone_emphasis(Pitches, KeyRoot) = Violations =>
    Len = length(Pitches),
    if Len < 1 then
        Violations = 0
    else
        LeadingTone = (KeyRoot + 11) mod 12,
        MaxAllowed = max(1, Len // 4),
        LTCount = length([P : P in Pitches, P mod 12 == LeadingTone]),
        Violations = max(0, LTCount - MaxAllowed)
    end.

% Score immediate repeats (consecutive same pitch)
score_immediate_repeats(Pitches) = Count =>
    Len = length(Pitches),
    if Len < 2 then
        Count = 0
    else
        Count = length([I : I in 1..Len-1, Pitches[I] == Pitches[I+1]])
    end.

% Score octave leaps
score_octave_leaps(Pitches, MaxAllowed) = Violations =>
    Len = length(Pitches),
    if Len < 2 then
        Violations = 0
    else
        OctaveCount = length([I : I in 1..Len-1, abs(Pitches[I+1] - Pitches[I]) >= 12]),
        Violations = max(0, OctaveCount - MaxAllowed)
    end.

% Score tonic anchoring (count windows without tonic)
score_tonic_anchoring(Pitches, KeyRoot) = Violations =>
    Len = length(Pitches),
    TonicPC = KeyRoot mod 12,
    NumWindows = Len // 4,
    if NumWindows < 1 then
        Violations = 0
    else
        Violations = NumWindows - count_windows_with_tonic(Pitches, TonicPC, NumWindows)
    end.

% Helper to count windows that contain tonic
count_windows_with_tonic(Pitches, TonicPC, NumWindows) = Count =>
    Count = length([W : W in 1..NumWindows,
        Start = (W - 1) * 4 + 1,
        End = min(Start + 3, length(Pitches)),
        WindowPCs = [Pitches[I] mod 12 : I in Start..End],
        membchk(TonicPC, WindowPCs)
    ]).

% Score prefer smaller intervals violations
% Returns sum of (interval_size - threshold) for intervals exceeding threshold
score_prefer_smaller_intervals(Pitches, Threshold) = Violations =>
    Len = length(Pitches),
    if Len < 2 then
        Violations = 0
    else
        Violations = sum([max(0, abs(Pitches[I+1] - Pitches[I]) - Threshold) : I in 1..Len-1])
    end.

% Score no repetitive intervals violations
% Counts runs of MaxConsecutive+1 identical intervals (same size AND direction)
score_no_repetitive_intervals(Pitches, MaxConsecutive) = Violations =>
    Len = length(Pitches),
    if Len < MaxConsecutive + 2 then
        Violations = 0
    else
        Intervals = [Pitches[I+1] - Pitches[I] : I in 1..Len-1],
        Violations = count_repetitive_runs(Intervals, MaxConsecutive)
    end.

% Helper: count runs of consecutive identical values exceeding max allowed
count_repetitive_runs(Intervals, MaxConsecutive) = Count =>
    Len = length(Intervals),
    Count = 0,
    I = 1,
    while (I =< Len - MaxConsecutive)
        AllSame = true,
        foreach(J in 1..MaxConsecutive, AllSame == true)
            if Intervals[I+J] != Intervals[I] then
                AllSame := false
            end
        end,
        if AllSame then
            Count := Count + 1
        end,
        I := I + 1
    end.

% Score large leap recovery violations
% A large leap (>= Threshold) needs stepwise motion on the other side
score_large_leap_recovery(Pitches, Threshold) = Violations =>
    Len = length(Pitches),
    if Len < 3 then
        Violations = 0
    else
        Count = 0,
        foreach(I in 2..Len-1)
            IntervalIn = abs(Pitches[I] - Pitches[I-1]),
            IntervalOut = abs(Pitches[I+1] - Pitches[I]),
            % Violation if large leap in AND non-stepwise out, OR large leap out AND non-stepwise in
            if (IntervalIn >= Threshold, IntervalOut > 2) ; (IntervalOut >= Threshold, IntervalIn > 2) then
                Count := Count + 1
            end
        end,
        Violations = Count
    end.

% Score consonant leaps only violations
% Dissonant leaps: 6 (tritone), 10 (m7), 11 (M7), >12 (beyond octave)
score_consonant_leaps_only(Pitches) = Violations =>
    Len = length(Pitches),
    if Len < 2 then
        Violations = 0
    else
        Count = 0,
        foreach(I in 1..Len-1)
            Interval = abs(Pitches[I+1] - Pitches[I]),
            % It's a leap (>2) and dissonant (6, 10, 11, or >12)
            if Interval > 2, (Interval == 6 ; Interval == 10 ; Interval == 11 ; Interval > 12) then
                Count := Count + 1
            end
        end,
        Violations = Count
    end.

% Score antecedent-consequent structure violations
% Checks: midpoint note is on degree 2, 5, or 7 (half cadence) AND
%          final note is on tonic (authentic cadence)
% Returns 0, 1, or 2
score_antecedent_consequent(Pitches, KeyRoot) = Violations =>
    Len = length(Pitches),
    if Len < 4 then
        Violations = 0
    else
        HalfPoint = Len // 2,
        RootPC = KeyRoot mod 12,
        SecondDegree = (KeyRoot + 2) mod 12,
        DominantPC = (KeyRoot + 7) mod 12,
        LeadingTone = (KeyRoot + 11) mod 12,
        % Check midpoint (half cadence feel: degree 2, 5, or 7)
        HalfPC = Pitches[HalfPoint] mod 12,
        HalfValid = cond(member(HalfPC, [SecondDegree, DominantPC, LeadingTone]), 1, 0),
        % Check end (authentic cadence feel)
        EndPC = Pitches[Len] mod 12,
        EndValid = cond(EndPC == RootPC, 1, 0),
        Violations = (1 - HalfValid) + (1 - EndValid)
    end.

% Score phrase rhyme violations
% Checks if first quarter and third quarter have matching contour directions
score_phrase_rhyme(Pitches) = Violations =>
    Len = length(Pitches),
    if Len < 8 then
        Violations = 0
    else
        QuarterLen = Len // 4,
        ThirdQuarterStart = Len // 2 + 1,
        Count = 0,
        foreach(I in 1..QuarterLen-1)
            % Direction in first quarter
            Dir1 = cond(Pitches[I+1] > Pitches[I], 1, cond(Pitches[I+1] < Pitches[I], -1, 0)),
            % Direction in third quarter (corresponding position)
            J = ThirdQuarterStart + I - 1,
            Dir2 = cond(Pitches[J+1] > Pitches[J], 1, cond(Pitches[J+1] < Pitches[J], -1, 0)),
            if Dir1 != Dir2 then Count := Count + 1 end
        end,
        Violations = Count
    end.

% Score authentic cadence melody violations
% Last two notes should be 2->1 or 7->1 (penultimate is degree 2 or 7, last is tonic)
score_authentic_cadence_melody(Pitches, KeyRoot) = Violations =>
    Len = length(Pitches),
    if Len < 2 then
        Violations = 0
    else
        RootPC = KeyRoot mod 12,
        SecondDegree = (KeyRoot + 2) mod 12,
        LeadingTone = (KeyRoot + 11) mod 12,
        LastPC = Pitches[Len] mod 12,
        PenultPC = Pitches[Len-1] mod 12,
        if LastPC == RootPC, member(PenultPC, [SecondDegree, LeadingTone]) then
            Violations = 0
        else
            Violations = 1
        end
    end.

% Score half cadence melody violations
% Last note should be on degree 2, 5, or 7 (non-tonic, half cadence feel)
score_half_cadence_melody(Pitches, KeyRoot) = Violations =>
    Len = length(Pitches),
    if Len < 1 then
        Violations = 0
    else
        SecondDegree = (KeyRoot + 2) mod 12,
        DominantPC = (KeyRoot + 7) mod 12,
        LeadingTone = (KeyRoot + 11) mod 12,
        LastPC = Pitches[Len] mod 12,
        if member(LastPC, [SecondDegree, DominantPC, LeadingTone]) then
            Violations = 0
        else
            Violations = 1
        end
    end.

% Score motivic repetition violations
% Checks if any 2-note interval pattern repeats at least once
% Returns 0 if repetition found (good), 1 if no repetition (bad)
score_motivic_repetition(Pitches) = Violations =>
    Len = length(Pitches),
    if Len < 5 then
        Violations = 0
    else
        Intervals = [Pitches[I+1] - Pitches[I] : I in 1..Len-1],
        HasRepeat = false,
        foreach(I in 1..length(Intervals)-1, HasRepeat == false)
            foreach(J in I+1..length(Intervals), HasRepeat == false)
                if Intervals[I] == Intervals[J] then
                    HasRepeat := true
                end
            end
        end,
        Violations = cond(HasRepeat, 0, 1)
    end.

% Score peak approach and exit violations
% Peak should be approached from below and left by descending step (1-2 semitones down)
score_peak_approach_exit(Pitches) = Violations =>
    Len = length(Pitches),
    if Len < 3 then
        Violations = 0
    else
        MaxPitch = max(Pitches),
        ApproachViolations = 0,
        ExitViolations = 0,
        foreach(I in 1..Len)
            if Pitches[I] == MaxPitch then
                % Check approach (should come from below)
                if I > 1, Pitches[I-1] >= Pitches[I] then
                    ApproachViolations := ApproachViolations + 1
                end,
                % Check exit (should descend by step: 1-2 semitones)
                if I < Len then
                    Descent = Pitches[I] - Pitches[I+1],
                    if Descent < 1 ; Descent > 2 then
                        ExitViolations := ExitViolations + 1
                    end
                end
            end
        end,
        Violations = ApproachViolations + ExitViolations
    end.

% ==============================================================================
% VOICE LEADING SCORERS (for SATB)
% ==============================================================================

% Count parallel fifths violations between two voices
count_parallel_fifths(Voice1, Voice2) = Count =>
    Len = length(Voice1),
    if Len < 2 then
        Count = 0
    else
        Count = length([I : I in 1..Len-1,
            Int1 = abs(Voice1[I] - Voice2[I]) mod 12,
            Int2 = abs(Voice1[I+1] - Voice2[I+1]) mod 12,
            M1 = Voice1[I+1] - Voice1[I],
            M2 = Voice2[I+1] - Voice2[I],
            Int1 == 7, Int2 == 7, M1 * M2 > 0
        ])
    end.

% Count parallel octaves violations
count_parallel_octaves(Voice1, Voice2) = Count =>
    Len = length(Voice1),
    if Len < 2 then
        Count = 0
    else
        Count = length([I : I in 1..Len-1,
            Int1 = abs(Voice1[I] - Voice2[I]) mod 12,
            Int2 = abs(Voice1[I+1] - Voice2[I+1]) mod 12,
            M1 = Voice1[I+1] - Voice1[I],
            M2 = Voice2[I+1] - Voice2[I],
            Int1 == 0, Int2 == 0, M1 * M2 > 0
        ])
    end.

% Count voice crossings
count_voice_crossings(HigherVoice, LowerVoice) = Count =>
    Count = length([I : I in 1..length(HigherVoice), HigherVoice[I] < LowerVoice[I]]).

% Count contrary motion instances
count_contrary(Voice1, Voice2) = Count =>
    Len = length(Voice1),
    if Len < 2 then
        Count = 0
    else
        Count = length([I : I in 1..Len-1,
            M1 = Voice1[I+1] - Voice1[I],
            M2 = Voice2[I+1] - Voice2[I],
            M1 * M2 < 0
        ])
    end.

% ==============================================================================
% ASSERTION HELPERS (following test_music_types.pi pattern)
% ==============================================================================

assert_eq(Actual, Expected, Msg) =>
    if Actual != Expected then
        printf("FAIL: %s - expected %w, got %w%n", Msg, Expected, Actual),
        fail
    end.

assert_true(Condition, Msg) =>
    if not Condition then
        printf("FAIL: %s%n", Msg),
        fail
    end.

assert_constraint_passes(ConstraintName, CheckPredicate) =>
    if not call(CheckPredicate) then
        printf("FAIL: %s constraint violated%n", ConstraintName),
        fail
    end.

assert_violation_count_below(ConstraintName, ActualCount, MaxAllowed, PieceId) =>
    if ActualCount > MaxAllowed then
        printf("FAIL: %w has %d %s violations (max: %d)%n",
               PieceId, ActualCount, ConstraintName, MaxAllowed),
        fail
    end.

assert_no_parallel_fifths(Voice1, Voice2, Label) =>
    Count = count_parallel_fifths(Voice1, Voice2),
    if Count > 0 then
        printf("FAIL: %s has %d parallel fifths%n", Label, Count),
        fail
    end.

assert_no_parallel_octaves(Voice1, Voice2, Label) =>
    Count = count_parallel_octaves(Voice1, Voice2),
    if Count > 0 then
        printf("FAIL: %s has %d parallel octaves%n", Label, Count),
        fail
    end.

assert_no_voice_crossing(HigherVoice, LowerVoice, Label) =>
    Count = count_voice_crossings(HigherVoice, LowerVoice),
    if Count > 0 then
        printf("FAIL: %s has %d voice crossings%n", Label, Count),
        fail
    end.

% ==============================================================================
% AUGMENTED SECOND CONSTRAINT TESTS
% ==============================================================================
% Tests the difference between the old (overly broad) and new (context-aware)
% augmented second constraints.

test_augmented_second_constraints =>
    println("Testing augmented second constraint variants..."),

    % Test 1: Minor third (C-Eb, 3 semitones) - should be ALLOWED
    % This is a leap of a 3rd in C minor, NOT an augmented 2nd
    MinorThirdMelody = [60, 63, 65, 67],  % C4, Eb4, F4, G4 in C minor
    CMinorRoot = 60,

    % Old constraint incorrectly FAILS on this (catches all 3-semitone intervals)
    (check_no_three_semitone_intervals(MinorThirdMelody) ->
        println("  UNEXPECTED: Old constraint passed on minor third (expected fail)")
    ;
        println("  OK: Old constraint correctly catches 3-semitone minor third (overly broad)")
    ),

    % New context-aware constraint should PASS (minor third is not between adjacent degrees)
    (check_no_augmented_seconds_in_scale(MinorThirdMelody, CMinorRoot, minor) ->
        println("  OK: Context-aware constraint correctly allows minor third (C-Eb)")
    ;
        println("FAIL: Context-aware constraint incorrectly rejects minor third"),
        fail
    ),

    % Test 2: True augmented second (Ab-B in C harmonic minor, degrees 6->7)
    % This SHOULD be forbidden by both constraints
    % C harmonic minor: C D Eb F G Ab B -> degrees 1 2 3 4 5 6 7
    % Ab (degree 6) to B (degree 7) = 3 semitones between adjacent degrees = aug 2nd
    AugSecondMelody = [67, 68, 71, 72],  % G4, Ab4, B4, C5 in C harmonic minor
    CHarmMinorRoot = 60,

    % Old constraint should FAIL (catches the 3-semitone Ab-B interval)
    (check_no_three_semitone_intervals(AugSecondMelody) ->
        println("FAIL: Old constraint should catch augmented second Ab-B"),
        fail
    ;
        println("  OK: Old constraint catches augmented second Ab-B")
    ),

    % New context-aware constraint should also FAIL (Ab-B is a true augmented 2nd)
    (check_no_augmented_seconds_in_scale(AugSecondMelody, CHarmMinorRoot, harmonic_minor) ->
        println("FAIL: Context-aware constraint should catch true augmented second Ab-B"),
        fail
    ;
        println("  OK: Context-aware constraint correctly catches augmented second Ab-B")
    ),

    % Test 3: Major scale melody with minor third leap (C-E, then E-G has no 3-semitone)
    % But let's test E-G# in A major which is a valid minor 3rd leap
    % Actually E-G# in A major is: E (degree 5) to G# (degree 7) = 4 semitones, not 3
    % Let's use F#-A in D major: F# (degree 3) to A (degree 5) = 3 semitones (minor 3rd)
    DMajorMelody = [62, 66, 69, 71],  % D4, F#4, A4, B4 in D major
    DMajorRoot = 62,  % D

    % F# to A is 3 semitones but degrees 3 to 5 (not adjacent) - should pass context-aware
    (check_no_augmented_seconds_in_scale(DMajorMelody, DMajorRoot, major) ->
        println("  OK: Context-aware allows minor 3rd leap F#-A in D major (degrees 3->5)")
    ;
        println("FAIL: Context-aware incorrectly rejects F#-A leap in D major"),
        fail
    ),

    println("Augmented second constraint tests passed!").

% ==============================================================================
% PHASE 2 STRUCTURAL CONSTRAINT TESTS
% Validates Phase 2 constraints against masterpieces:
%   antecedent_consequent, phrase_rhyme, authentic_cadence_melody,
%   half_cadence_melody, motivic_repetition, peak_approach_exit
% ==============================================================================

test_phase2_structural_constraints =>
    println("Testing Phase 2 structural constraints..."),

    % --- Antecedent-Consequent Structure ---
    % K545 has clear period structure: ends on C (tonic), midpoint should be non-tonic
    K545Pitches = get_melody(k545_theme()),
    K545Key = get_key(k545_theme()),
    K545AC = score_antecedent_consequent(K545Pitches, K545Key),
    printf("  K545 antecedent-consequent violations: %d%n", K545AC),
    % K545 ends on tonic (0 violations for end), midpoint may or may not match
    assert_violation_count_below("antecedent_consequent", K545AC, 2, mozart_k545_theme),

    % K331 has clear antecedent-consequent (A major, ends on tonic)
    K331Pitches = get_melody(k331_theme()),
    K331Key = get_key(k331_theme()),
    K331AC = score_antecedent_consequent(K331Pitches, K331Key),
    printf("  K331 antecedent-consequent violations: %d%n", K331AC),
    assert_violation_count_below("antecedent_consequent", K331AC, 2, mozart_k331_theme),

    % Twinkle Twinkle has clear period structure (ends on tonic)
    TwinklePitches = get_melody(twinkle_twinkle()),
    TwinkleKey = get_key(twinkle_twinkle()),
    TwinkleAC = score_antecedent_consequent(TwinklePitches, TwinkleKey),
    printf("  Twinkle antecedent-consequent violations: %d%n", TwinkleAC),
    assert_violation_count_below("antecedent_consequent", TwinkleAC, 2, twinkle_twinkle),

    % --- Phrase Rhyme ---
    % K545 theme: first phrase and third quarter should have similar contour
    K545Rhyme = score_phrase_rhyme(K545Pitches),
    printf("  K545 phrase rhyme violations: %d%n", K545Rhyme),
    % Allow some mismatches (classical music has variations in repetition)
    QuarterLen545 = length(K545Pitches) // 4,
    assert_violation_count_below("phrase_rhyme", K545Rhyme, max(3, QuarterLen545), mozart_k545_theme),

    % K331 has very strong phrase rhyme (repeated opening material)
    K331Rhyme = score_phrase_rhyme(K331Pitches),
    printf("  K331 phrase rhyme violations: %d%n", K331Rhyme),
    QuarterLen331 = length(K331Pitches) // 4,
    assert_violation_count_below("phrase_rhyme", K331Rhyme, max(3, QuarterLen331), mozart_k331_theme),

    % --- Authentic Cadence Melody ---
    % K545 ends with D4-C4 (2->1), should have 0 violations
    K545Cadence = score_authentic_cadence_melody(K545Pitches, K545Key),
    printf("  K545 authentic cadence violations: %d%n", K545Cadence),
    assert_violation_count_below("authentic_cadence_melody", K545Cadence, 0, mozart_k545_theme),

    % Ode to Joy ends on tonic with proper cadence
    OdePitches = get_melody(ode_to_joy()),
    OdeKey = get_key(ode_to_joy()),
    OdeCadence = score_authentic_cadence_melody(OdePitches, OdeKey),
    printf("  Ode to Joy authentic cadence violations: %d%n", OdeCadence),
    assert_violation_count_below("authentic_cadence_melody", OdeCadence, 1, ode_to_joy),

    % --- Half Cadence Melody ---
    % K545 first phrase alone (antecedent) - should end in a way amenable to half cadence
    % Note: first phrase of K545 ends on C (tonic), so as a standalone test it won't pass half cadence
    % Instead test on Symphony 40 which ends on D (dominant of G minor)
    Sym40Pitches = get_melody(symphony40_theme()),
    Sym40Key = get_key(symphony40_theme()),
    Sym40Half = score_half_cadence_melody(Sym40Pitches, Sym40Key),
    printf("  Symphony 40 half cadence violations: %d%n", Sym40Half),
    % Sym40 ends on D4 = degree 5 of G minor, so should pass
    assert_violation_count_below("half_cadence_melody", Sym40Half, 0, mozart_symphony40_theme),

    % --- Motivic Repetition ---
    % All classical pieces should have motivic repetition
    K545Motivic = score_motivic_repetition(K545Pitches),
    printf("  K545 motivic repetition violations: %d%n", K545Motivic),
    assert_violation_count_below("motivic_repetition", K545Motivic, 0, mozart_k545_theme),

    K331Motivic = score_motivic_repetition(K331Pitches),
    printf("  K331 motivic repetition violations: %d%n", K331Motivic),
    assert_violation_count_below("motivic_repetition", K331Motivic, 0, mozart_k331_theme),

    OdeMotivic = score_motivic_repetition(OdePitches),
    printf("  Ode to Joy motivic repetition violations: %d%n", OdeMotivic),
    assert_violation_count_below("motivic_repetition", OdeMotivic, 0, ode_to_joy),

    % --- Peak Approach/Exit ---
    K545Peak = score_peak_approach_exit(K545Pitches),
    printf("  K545 peak approach/exit violations: %d%n", K545Peak),
    % Classical melodies handle peaks well, but allow some flexibility
    assert_violation_count_below("peak_approach_exit", K545Peak, 4, mozart_k545_theme),

    OdePeak = score_peak_approach_exit(OdePitches),
    printf("  Ode to Joy peak approach/exit violations: %d%n", OdePeak),
    assert_violation_count_below("peak_approach_exit", OdePeak, 4, ode_to_joy),

    println("  Phase 2 structural constraints: OK").

% ==============================================================================
% MAIN ENTRY POINT
% ==============================================================================

main(Args) => main.

main =>
    println("=== Famous Pieces Constraint Validation Test Suite ==="),
    println("Validating that famous masterpieces satisfy our music theory constraints"),
    println(""),

    PassCount = 0,
    FailCount = 0,

    % Run all test categories
    (test_augmented_second_constraints() -> PassCount := PassCount + 1 ; FailCount := FailCount + 1),
    (test_folk_melodies() -> PassCount := PassCount + 1 ; FailCount := FailCount + 1),
    (test_bach_satb() -> PassCount := PassCount + 1 ; FailCount := FailCount + 1),
    (test_bach_melodies() -> PassCount := PassCount + 1 ; FailCount := FailCount + 1),
    (test_mozart_melodies() -> PassCount := PassCount + 1 ; FailCount := FailCount + 1),
    (test_beethoven_melodies() -> PassCount := PassCount + 1 ; FailCount := FailCount + 1),
    (test_soft_constraint_baselines() -> PassCount := PassCount + 1 ; FailCount := FailCount + 1),
    (test_phase2_structural_constraints() -> PassCount := PassCount + 1 ; FailCount := FailCount + 1),
    (test_masterpiece_integration() -> PassCount := PassCount + 1 ; FailCount := FailCount + 1),

    println(""),
    println("=== Test Summary ==="),
    printf("Passed: %d%n", PassCount),
    printf("Failed: %d%n", FailCount),
    if FailCount == 0 then
        println("All tests passed! Famous pieces validate our constraints.")
    else
        println("Some tests failed - constraint definitions may need adjustment."),
        fail
    end.

% ==============================================================================
% FOLK MELODY TESTS
% Tests basic melodic constraints on simple, well-known tunes
% ==============================================================================

test_folk_melodies =>
    println("Testing folk melodies..."),

    % Twinkle Twinkle - very simple, should pass all basic constraints
    TwinklePitches = get_melody(twinkle_twinkle()),
    TwinkleKey = get_key(twinkle_twinkle()),

    % Check max range (should be within 12 semitones for children's song)
    (check_max_range(TwinklePitches, 12) -> true
     ; println("FAIL: twinkle: max_range <= 12"), fail),

    % Check ends on tonic
    (check_ends_on_tonic(TwinklePitches, TwinkleKey) -> true
     ; println("FAIL: twinkle: ends_on_tonic"), fail),

    % Mary Had a Little Lamb - extremely simple range
    MaryPitches = get_melody(mary_had_a_little_lamb()),
    MaryKey = get_key(mary_had_a_little_lamb()),

    (check_max_range(MaryPitches, 8) -> true
     ; println("FAIL: mary: max_range <= 8"), fail),
    (check_ends_on_tonic(MaryPitches, MaryKey) -> true
     ; println("FAIL: mary: ends_on_tonic"), fail),

    % Amazing Grace - tests arch contour and leap recovery
    GracePitches = get_melody(amazing_grace()),
    GraceKey = get_key(amazing_grace()),

    (check_ends_on_tonic(GracePitches, GraceKey) -> true
     ; println("FAIL: amazing_grace: ends_on_tonic"), fail),
    (check_max_range(GracePitches, 15) -> true
     ; println("FAIL: amazing_grace: max_range <= 15"), fail),

    % Frere Jacques - ends on tonic, simple structure
    FrerePitches = get_melody(frere_jacques()),
    FrereKey = get_key(frere_jacques()),

    (check_ends_on_tonic(FrerePitches, FrereKey) -> true
     ; println("FAIL: frere_jacques: ends_on_tonic"), fail),

    % Auld Lang Syne - ends on tonic
    AuldPitches = get_melody(auld_lang_syne()),
    AuldKey = get_key(auld_lang_syne()),

    (check_ends_on_tonic(AuldPitches, AuldKey) -> true
     ; println("FAIL: auld_lang_syne: ends_on_tonic"), fail),

    println("  Folk melodies: OK").

% ==============================================================================
% BACH SATB TESTS
% Tests voice leading constraints on 4-part chorales
% ==============================================================================

test_bach_satb =>
    println("Testing Bach SATB chorales..."),

    % BWV 269 - "O Haupt voll Blut und Wunden"
    BWV269 = bwv269_bars1_4(),
    {S1, A1, T1, B1} = get_satb(BWV269),

    % Test no parallel fifths - outer voices (S-B) are most critical
    assert_no_parallel_fifths(S1, B1, "BWV269 S-B"),

    % Test no parallel octaves - focus on outer voices
    % Inner voice parallels are less critical and may appear in simplified transcriptions
    assert_no_parallel_octaves(S1, B1, "BWV269 S-B"),

    % Test no voice crossing
    assert_no_voice_crossing(S1, A1, "BWV269 S-A"),
    assert_no_voice_crossing(A1, T1, "BWV269 A-T"),
    assert_no_voice_crossing(T1, B1, "BWV269 T-B"),

    % BWV 253 - "Ach bleib bei uns"
    BWV253 = bwv253_bars1_4(),
    {S2, A2, T2, B2} = get_satb(BWV253),

    % Test no parallel fifths - outer voices
    assert_no_parallel_fifths(S2, B2, "BWV253 S-B"),

    % Test no parallel octaves - outer voices
    assert_no_parallel_octaves(S2, B2, "BWV253 S-B"),

    % Test no voice crossing (soprano always above alto, etc.)
    assert_no_voice_crossing(S2, A2, "BWV253 S-A"),
    assert_no_voice_crossing(A2, T2, "BWV253 A-T"),
    assert_no_voice_crossing(T2, B2, "BWV253 T-B"),

    println("  Bach SATB chorales: OK").

% ==============================================================================
% BACH MELODY TESTS
% Tests melodic constraints on inventions and preludes
% ==============================================================================

test_bach_melodies =>
    println("Testing Bach melodies..."),

    % Invention No. 1 - tests stepwise motion, sequence patterns
    % Note: The invention subject is arpeggio-based (C-E-G patterns), so stepwise
    % threshold is lower than for purely melodic pieces. 30% accounts for
    % the characteristic Baroque keyboard figuration.
    Inv1Pitches = get_melody(invention1_subject()),

    % Should have some stepwise motion, but allow for arpeggio patterns
    StepwisePercent = stepwise_percent(Inv1Pitches),
    (StepwisePercent >= 30 -> true
     ; printf("FAIL: invention1: stepwise >= 30%% (got %d%%)%n", StepwisePercent), fail),

    % Should have reasonable range
    (check_max_range(Inv1Pitches, 15) -> true
     ; println("FAIL: invention1: max_range <= 15"), fail),

    % Invention No. 4 (D minor) - test range and stepwise motion
    % Note: The subject has minor third intervals (e.g., F4->D4) which are valid.
    % The no_augmented_seconds constraint catches ALL 3-semitone intervals,
    % but minor thirds are common and acceptable in melodies.
    Inv4Pitches = get_melody(invention4_subject()),
    (check_max_range(Inv4Pitches, 12) -> true
     ; println("FAIL: invention4: max_range <= 12"), fail),

    % Invention No. 8 - very stepwise
    Inv8Pitches = get_melody(invention8_subject()),
    Inv8Stepwise = stepwise_percent(Inv8Pitches),
    (Inv8Stepwise >= 60 -> true
     ; printf("FAIL: invention8: stepwise >= 60%% (got %d%%)%n", Inv8Stepwise), fail),

    % WTC Prelude in C - mostly stepwise top line
    WTCPitches = get_melody(wtc1_prelude_c()),
    WTCStepwise = stepwise_percent(WTCPitches),
    (WTCStepwise >= 70 -> true
     ; printf("FAIL: wtc1_prelude: stepwise >= 70%% (got %d%%)%n", WTCStepwise), fail),

    println("  Bach melodies: OK").

% ==============================================================================
% MOZART MELODY TESTS
% Tests Classical period phrase structure and contour
% ==============================================================================

test_mozart_melodies =>
    println("Testing Mozart melodies..."),

    % K. 545 "Facile" - clear phrase structure, ends on tonic
    K545Pitches = get_melody(k545_theme()),
    K545Key = get_key(k545_theme()),

    (check_ends_on_tonic(K545Pitches, K545Key) -> true
     ; println("FAIL: k545: ends_on_tonic"), fail),
    (check_max_range(K545Pitches, 20) -> true
     ; println("FAIL: k545: max_range <= 20"), fail),

    % K. 331 Theme - very balanced, ends on tonic
    K331Pitches = get_melody(k331_theme()),
    K331Key = get_key(k331_theme()),

    (check_ends_on_tonic(K331Pitches, K331Key) -> true
     ; println("FAIL: k331: ends_on_tonic"), fail),

    % Eine Kleine Nachtmusik - famous opening
    EinePitches = get_melody(eine_kleine_theme()),

    (check_max_range(EinePitches, 20) -> true
     ; println("FAIL: eine_kleine: max_range <= 20"), fail),

    % Symphony 40 - G minor, phrase ends stable
    Sym40Pitches = get_melody(symphony40_theme()),
    Sym40Key = get_key(symphony40_theme()),

    % In minor mode, ends stable (on 5th degree)
    (check_phrase_ends_stable(Sym40Pitches, Sym40Key) -> true
     ; println("FAIL: symphony40: ends_stable"), fail),

    % K. 333 Theme - graceful, balanced
    K333Pitches = get_melody(k333_theme()),
    K333Key = get_key(k333_theme()),

    (check_ends_on_tonic(K333Pitches, K333Key) -> true
     ; println("FAIL: k333: ends_on_tonic"), fail),

    println("  Mozart melodies: OK").

% ==============================================================================
% BEETHOVEN MELODY TESTS
% Tests Romantic/Late Classical melodic features
% ==============================================================================

test_beethoven_melodies =>
    println("Testing Beethoven melodies..."),

    % Ode to Joy - extremely stepwise, ends on tonic
    OdePitches = get_melody(ode_to_joy()),
    OdeKey = get_key(ode_to_joy()),

    OdeStepwise = stepwise_percent(OdePitches),
    (OdeStepwise >= 70 -> true
     ; printf("FAIL: ode_to_joy: stepwise >= 70%% (got %d%%)%n", OdeStepwise), fail),
    (check_ends_on_tonic(OdePitches, OdeKey) -> true
     ; println("FAIL: ode_to_joy: ends_on_tonic"), fail),

    % Fur Elise - characteristic A minor theme
    FurPitches = get_melody(fur_elise_theme()),
    FurKey = get_key(fur_elise_theme()),

    % Should return to tonic region (A)
    (check_phrase_ends_stable(FurPitches, FurKey) -> true
     ; println("FAIL: fur_elise: ends_stable"), fail),

    % Pathetique Adagio - beautiful arch contour, ends on tonic
    PathPitches = get_melody(pathetique_adagio()),
    PathKey = get_key(pathetique_adagio()),

    (check_ends_on_tonic(PathPitches, PathKey) -> true
     ; println("FAIL: pathetique: ends_on_tonic"), fail),

    % Pastoral Symphony - F major theme, ends on tonic
    PastPitches = get_melody(pastoral_theme()),
    PastKey = get_key(pastoral_theme()),

    (check_ends_on_tonic(PastPitches, PastKey) -> true
     ; println("FAIL: pastoral: ends_on_tonic"), fail),

    % Symphony 5 motif - characteristic short-short-short-long
    Sym5Pitches = get_melody(symphony5_motif()),

    % Should have limited range for the motif
    (check_max_range(Sym5Pitches, 12) -> true
     ; println("FAIL: symphony5: max_range <= 12"), fail),

    println("  Beethoven melodies: OK").

% ==============================================================================
% SOFT CONSTRAINT BASELINE TESTS
% Establishes baseline violation counts for soft constraints
% These don't fail but report metrics for comparison with generated music
% ==============================================================================

test_soft_constraint_baselines =>
    println("Testing soft constraint baselines..."),
    println("  (Reporting violation counts for comparison with generated music)"),

    % Test leap recovery on various pieces
    test_leap_recovery_baselines(),

    % Test balanced motion
    test_balanced_motion_baselines(),

    % Test single climax
    test_climax_baselines(),

    println("  Soft constraint baselines: OK").

test_leap_recovery_baselines =>
    % Folk pieces should have good leap recovery
    TwinkleLeaps = score_leap_recovery(get_melody(twinkle_twinkle())),
    MaryLeaps = score_leap_recovery(get_melody(mary_had_a_little_lamb())),

    assert_violation_count_below("leap_recovery", TwinkleLeaps, 2, twinkle_twinkle),
    assert_violation_count_below("leap_recovery", MaryLeaps, 1, mary_had_a_little_lamb),

    % Classical themes should also recover well
    OdeLeaps = score_leap_recovery(get_melody(ode_to_joy())),
    assert_violation_count_below("leap_recovery", OdeLeaps, 3, ode_to_joy).

test_balanced_motion_baselines =>
    % Mozart should be balanced
    K545Motion = score_balanced_motion(get_melody(k545_theme()), 30),
    assert_violation_count_below("balanced_motion", K545Motion, 3, k545_theme),

    % Ode to Joy is very balanced
    OdeMotion = score_balanced_motion(get_melody(ode_to_joy()), 30),
    assert_violation_count_below("balanced_motion", OdeMotion, 3, ode_to_joy).

test_climax_baselines =>
    % Test single climax scoring
    K545Climax = score_single_climax(get_melody(k545_first_phrase())),
    assert_violation_count_below("single_climax", K545Climax, 2, k545_first_phrase),

    % Amazing Grace should have clear climax
    GraceClimax = score_single_climax(get_melody(amazing_grace())),
    assert_violation_count_below("single_climax", GraceClimax, 2, amazing_grace).

% ==============================================================================
% HELPER: COUNT SATB VOICE LEADING VIOLATIONS
% Returns total number of failures for a SATB excerpt
% Focus on outer voice (S-B) parallelisms which are most critical,
% plus voice crossings for all adjacent pairs.
% Inner voice parallelisms are less critical in simplified transcriptions.
% ==============================================================================

count_satb_failures(S, A, T, B) = Failures =>
    % Critical: outer voice (S-B) parallel fifths and octaves
    P5_SB = cond(count_parallel_fifths(S, B) > 0, 1, 0),
    P8_SB = cond(count_parallel_octaves(S, B) > 0, 1, 0),

    % Voice crossings for adjacent pairs
    VC_SA = cond(count_voice_crossings(S, A) > 0, 1, 0),
    VC_AT = cond(count_voice_crossings(A, T) > 0, 1, 0),
    VC_TB = cond(count_voice_crossings(T, B) > 0, 1, 0),

    Failures = P5_SB + P8_SB + VC_SA + VC_AT + VC_TB.

% ==============================================================================
% MASTERPIECE INTEGRATION TEST
% Comprehensive test that validates ALL pieces against ALL applicable constraints
% This serves as the ultimate validation that our constraints match real music
% ==============================================================================

test_masterpiece_integration =>
    println(""),
    println("=== MASTERPIECE INTEGRATION TEST ==="),
    println("Comprehensive validation of all constraints against all pieces"),
    println(""),

    % Track statistics
    TotalTests = 0,
    PassedTests = 0,
    FailedTests = 0,

    % ==== FOLK MELODIES ====
    println("--- Folk Melodies ---"),
    FolkPieces = [
        twinkle_twinkle(),
        mary_had_a_little_lamb(),
        amazing_grace(),
        greensleeves(),
        scarborough_fair(),
        auld_lang_syne(),
        frere_jacques()
    ],
    foreach(Piece in FolkPieces)
        Pitches = get_melody(Piece),
        Key = get_key(Piece),
        Id = get_id(Piece),

        % Test ends_on_tonic or ends_stable
        TotalTests := TotalTests + 1,
        if check_ends_on_tonic(Pitches, Key) ; check_phrase_ends_stable(Pitches, Key) then
            PassedTests := PassedTests + 1
        else
            printf("  FAIL: %w - doesn't end on tonic or stable%n", Id),
            FailedTests := FailedTests + 1
        end,

        % Test max_range (folk songs should be singable)
        TotalTests := TotalTests + 1,
        if check_max_range(Pitches, 20) then
            PassedTests := PassedTests + 1
        else
            printf("  FAIL: %w - range exceeds 20 semitones%n", Id),
            FailedTests := FailedTests + 1
        end
    end,
    printf("  Folk: %d tests%n", length(FolkPieces) * 2),

    % ==== BACH SATB CHORALES ====
    println("--- Bach SATB Chorales ---"),

    % Test BWV 269
    BWV269 = bwv269_bars1_4(),
    {S269, A269, T269, B269} = get_satb(BWV269),
    Failures269 = count_satb_failures(S269, A269, T269, B269),
    TotalTests := TotalTests + 5,  % S-B fifths, S-B octaves, 3 voice crossings
    PassedTests := PassedTests + (5 - Failures269),
    FailedTests := FailedTests + Failures269,
    if Failures269 > 0 then printf("  FAIL: bwv269_bars1_4 has %d voice leading violations%n", Failures269) end,

    % Test BWV 253
    BWV253 = bwv253_bars1_4(),
    {S253, A253, T253, B253} = get_satb(BWV253),
    Failures253 = count_satb_failures(S253, A253, T253, B253),
    TotalTests := TotalTests + 5,  % S-B fifths, S-B octaves, 3 voice crossings
    PassedTests := PassedTests + (5 - Failures253),
    FailedTests := FailedTests + Failures253,
    if Failures253 > 0 then printf("  FAIL: bwv253_bars1_4 has %d voice leading violations%n", Failures253) end,

    printf("  Bach SATB: 10 tests%n"),

    % ==== BACH MELODIES ====
    println("--- Bach Melodies ---"),
    BachMelodies = [
        invention1_subject(),
        invention1_bars1_4(),
        invention4_subject(),
        invention8_subject(),
        wtc1_prelude_c()
    ],
    foreach(Piece in BachMelodies)
        Pitches = get_melody(Piece),
        Id = get_id(Piece),

        % Bach melodies should have stepwise motion, allowing for arpeggio patterns
        TotalTests := TotalTests + 1,
        StepPercent = stepwise_percent(Pitches),
        if StepPercent >= 30 then
            PassedTests := PassedTests + 1
        else
            printf("  FAIL: %w - only %d%% stepwise (need 30%%)%n", Id, StepPercent),
            FailedTests := FailedTests + 1
        end,

        % Range should be reasonable
        TotalTests := TotalTests + 1,
        if check_max_range(Pitches, 24) then
            PassedTests := PassedTests + 1
        else
            printf("  FAIL: %w - range exceeds 2 octaves%n", Id),
            FailedTests := FailedTests + 1
        end
    end,
    printf("  Bach Melodies: %d tests%n", length(BachMelodies) * 2),

    % ==== MOZART MELODIES ====
    println("--- Mozart Melodies ---"),
    MozartPieces = [
        k545_theme(),
        k545_first_phrase(),
        k331_theme(),
        k333_theme(),
        eine_kleine_theme(),
        symphony40_theme()
    ],
    foreach(Piece in MozartPieces)
        Pitches = get_melody(Piece),
        Key = get_key(Piece),
        Id = get_id(Piece),

        % Mozart phrases should end stable
        TotalTests := TotalTests + 1,
        if check_phrase_ends_stable(Pitches, Key) ; check_ends_on_tonic(Pitches, Key) then
            PassedTests := PassedTests + 1
        else
            printf("  FAIL: %w - doesn't end stable%n", Id),
            FailedTests := FailedTests + 1
        end,

        % Range reasonable
        TotalTests := TotalTests + 1,
        if check_max_range(Pitches, 24) then
            PassedTests := PassedTests + 1
        else
            printf("  FAIL: %w - range exceeds 2 octaves%n", Id),
            FailedTests := FailedTests + 1
        end,

        % Balanced motion (allow up to 40% tolerance)
        TotalTests := TotalTests + 1,
        MotionViolations = score_balanced_motion(Pitches, 40),
        if MotionViolations =< 3 then
            PassedTests := PassedTests + 1
        else
            printf("  FAIL: %w - %d motion imbalance violations%n", Id, MotionViolations),
            FailedTests := FailedTests + 1
        end
    end,
    printf("  Mozart: %d tests%n", length(MozartPieces) * 3),

    % ==== BEETHOVEN MELODIES ====
    println("--- Beethoven Melodies ---"),
    BeethovenPieces = [
        ode_to_joy(),
        ode_to_joy_d_major(),
        fur_elise_theme(),
        symphony5_motif(),
        pathetique_adagio(),
        moonlight_melody(),
        pastoral_theme()
    ],
    foreach(Piece in BeethovenPieces)
        Pitches = get_melody(Piece),
        Key = get_key(Piece),
        Id = get_id(Piece),

        % Should end stable (on 1, 3, or 5)
        TotalTests := TotalTests + 1,
        if check_phrase_ends_stable(Pitches, Key) ; check_ends_on_tonic(Pitches, Key) then
            PassedTests := PassedTests + 1
        else
            printf("  FAIL: %w - doesn't end stable%n", Id),
            FailedTests := FailedTests + 1
        end,

        % Range reasonable
        TotalTests := TotalTests + 1,
        if check_max_range(Pitches, 24) then
            PassedTests := PassedTests + 1
        else
            printf("  FAIL: %w - range exceeds 2 octaves%n", Id),
            FailedTests := FailedTests + 1
        end,

        % Leap recovery should be reasonable
        TotalTests := TotalTests + 1,
        LeapViolations = score_leap_recovery(Pitches),
        MaxLeapViolations = max(3, length(Pitches) // 5),
        if LeapViolations =< MaxLeapViolations then
            PassedTests := PassedTests + 1
        else
            printf("  FAIL: %w - %d leap recovery violations (max %d)%n", Id, LeapViolations, MaxLeapViolations),
            FailedTests := FailedTests + 1
        end
    end,
    printf("  Beethoven: %d tests%n", length(BeethovenPieces) * 3),

    % ==== CROSS-COMPOSER SOFT CONSTRAINT VALIDATION ====
    println("--- Cross-Composer Soft Constraints ---"),
    AllMelodies = FolkPieces ++ BachMelodies ++ MozartPieces ++ BeethovenPieces,

    % Count total soft constraint violations across all pieces
    TotalLeapViolations = 0,
    TotalStepwiseViolations = 0,
    TotalClimaxViolations = 0,
    TotalRepeatViolations = 0,

    foreach(Piece in AllMelodies)
        Pitches = get_melody(Piece),
        _ = get_key(Piece),  % Key available if needed in future

        TotalLeapViolations := TotalLeapViolations + score_leap_recovery(Pitches),
        TotalStepwiseViolations := TotalStepwiseViolations + score_mostly_stepwise(Pitches, 30),
        TotalClimaxViolations := TotalClimaxViolations + score_single_climax(Pitches),
        TotalRepeatViolations := TotalRepeatViolations + score_immediate_repeats(Pitches)
    end,

    NumMelodies = length(AllMelodies),
    printf("  Avg leap recovery violations: %.1f per piece%n", TotalLeapViolations / NumMelodies),
    printf("  Avg stepwise violations (30%% threshold): %.1f per piece%n", TotalStepwiseViolations / NumMelodies),
    printf("  Avg climax violations: %.1f per piece%n", TotalClimaxViolations / NumMelodies),
    printf("  Avg immediate repeat count: %.1f per piece%n", TotalRepeatViolations / NumMelodies),

    % Verify averages are reasonable
    TotalTests := TotalTests + 1,
    AvgLeap = TotalLeapViolations / NumMelodies,
    if AvgLeap =< 3.0 then
        PassedTests := PassedTests + 1
    else
        printf("  FAIL: Average leap recovery violations too high (%.1f > 3.0)%n", AvgLeap),
        FailedTests := FailedTests + 1
    end,

    TotalTests := TotalTests + 1,
    AvgClimax = TotalClimaxViolations / NumMelodies,
    if AvgClimax =< 2.0 then
        PassedTests := PassedTests + 1
    else
        printf("  FAIL: Average climax violations too high (%.1f > 2.0)%n", AvgClimax),
        FailedTests := FailedTests + 1
    end,

    % ==== FINAL SUMMARY ====
    println(""),
    println("=== MASTERPIECE INTEGRATION SUMMARY ==="),
    printf("Total tests run: %d%n", TotalTests),
    printf("Passed: %d%n", PassedTests),
    printf("Failed: %d%n", FailedTests),
    PassRate = (PassedTests * 100) // TotalTests,
    printf("Pass rate: %d%%%n", PassRate),

    % Must have at least 85% pass rate (allowing for minor transcription variations)
    if PassRate >= 85 then
        println("SUCCESS: Masterpiece integration test passed!"),
        println("Our constraints are validated against real musical masterpieces.")
    else
        printf("FAIL: Pass rate %d%% is below 85%% threshold%n", PassRate),
        fail
    end.
