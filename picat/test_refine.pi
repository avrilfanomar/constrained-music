% test_refine.pi - Tests for post-generation refinement
%
% Tests score_for_refinement, boost_worst_constraints, extract_pitches,
% and integration with genre-based generation.

module test_refine.

import refiner.
import visualizer.
import constraint_selector.
import genre_profiles.
import melody.
import music_types.
import mood_mapping.
import mood.

main =>
    println("=== Refinement Tests ==="),
    nl,
    PassCount = 0,
    FailCount = 0,

    % --- Scoring tests ---
    println("Scoring:"),

    printf("  %-50s", "score_for_refinement returns integer >= 0"),
    (test_score_returns_integer() -> println("[PASS]"), PassCount := PassCount + 1
     ; println("[FAIL]"), FailCount := FailCount + 1),

    printf("  %-50s", "worse melody scores higher"),
    (test_worse_scores_higher() -> println("[PASS]"), PassCount := PassCount + 1
     ; println("[FAIL]"), FailCount := FailCount + 1),

    printf("  %-50s", "scoring uses genre weights"),
    (test_scoring_uses_genre_weights() -> println("[PASS]"), PassCount := PassCount + 1
     ; println("[FAIL]"), FailCount := FailCount + 1),

    % --- Boosting tests ---
    nl,
    println("Weight Boosting:"),

    printf("  %-50s", "boost_worst_constraints returns preferences"),
    (test_boost_returns_prefs() -> println("[PASS]"), PassCount := PassCount + 1
     ; println("[FAIL]"), FailCount := FailCount + 1),

    printf("  %-50s", "boosted prefs contain weight_override entries"),
    (test_boost_has_overrides() -> println("[PASS]"), PassCount := PassCount + 1
     ; println("[FAIL]"), FailCount := FailCount + 1),

    printf("  %-50s", "boost multiplier increases with round"),
    (test_boost_multiplier_increases() -> println("[PASS]"), PassCount := PassCount + 1
     ; println("[FAIL]"), FailCount := FailCount + 1),

    % --- Extraction tests ---
    nl,
    println("Pitch Extraction:"),

    printf("  %-50s", "extract_pitches from note list"),
    (test_extract_pitches() -> println("[PASS]"), PassCount := PassCount + 1
     ; println("[FAIL]"), FailCount := FailCount + 1),

    printf("  %-50s", "extract_pitches empty list"),
    (test_extract_pitches_empty() -> println("[PASS]"), PassCount := PassCount + 1
     ; println("[FAIL]"), FailCount := FailCount + 1),

    % --- Helper tests ---
    nl,
    println("Helpers:"),

    printf("  %-50s", "get_refine_rounds default is 1"),
    (test_get_refine_rounds_default() -> println("[PASS]"), PassCount := PassCount + 1
     ; println("[FAIL]"), FailCount := FailCount + 1),

    printf("  %-50s", "get_refine_rounds from preferences"),
    (test_get_refine_rounds_set() -> println("[PASS]"), PassCount := PassCount + 1
     ; println("[FAIL]"), FailCount := FailCount + 1),

    printf("  %-50s", "get_refine_piece_rounds default is 1"),
    (test_get_refine_piece_default() -> println("[PASS]"), PassCount := PassCount + 1
     ; println("[FAIL]"), FailCount := FailCount + 1),

    printf("  %-50s", "format_boosted shows constraint names"),
    (test_format_boosted() -> println("[PASS]"), PassCount := PassCount + 1
     ; println("[FAIL]"), FailCount := FailCount + 1),

    printf("  %-50s", "ensure_min_randomness bumps low values"),
    (test_ensure_min_randomness() -> println("[PASS]"), PassCount := PassCount + 1
     ; println("[FAIL]"), FailCount := FailCount + 1),

    printf("  %-50s", "ensure_min_randomness keeps high values"),
    (test_ensure_min_randomness_high() -> println("[PASS]"), PassCount := PassCount + 1
     ; println("[FAIL]"), FailCount := FailCount + 1),

    % --- Integration tests ---
    nl,
    println("Integration:"),

    printf("  %-50s", "score real generated melody"),
    (test_score_real_melody() -> println("[PASS]"), PassCount := PassCount + 1
     ; println("[FAIL]"), FailCount := FailCount + 1),

    printf("  %-50s", "boost on real melody identifies constraints"),
    (test_boost_real_melody() -> println("[PASS]"), PassCount := PassCount + 1
     ; println("[FAIL]"), FailCount := FailCount + 1),

    % --- Summary ---
    nl,
    Total = PassCount + FailCount,
    printf("=== Results: %d/%d passed ===%n", PassCount, Total),
    if FailCount > 0 then
        printf("FAILURES: %d%n", FailCount),
        halt(1)
    else
        println("All refinement tests passed!")
    end.

% ==============================================================================
% SCORING TESTS
% ==============================================================================

% Twinkle Twinkle melody (known good)
twinkle_pitches() = [60, 60, 67, 67, 69, 69, 67, 65, 65, 64, 64, 62, 62, 60].

% Chromatic mess (known bad)
chromatic_pitches() = [60, 61, 62, 63, 64, 65, 66, 67, 68, 69, 70, 71].

test_score_returns_integer() =>
    Pitches = twinkle_pitches(),
    Score = refiner.score_for_refinement(Pitches, 60, classical_period, []),
    integer(Score),
    Score >= 0.

test_worse_scores_higher() =>
    GoodPitches = twinkle_pitches(),
    BadPitches = chromatic_pitches(),
    GoodScore = refiner.score_for_refinement(GoodPitches, 60, classical_period, []),
    BadScore = refiner.score_for_refinement(BadPitches, 60, classical_period, []),
    BadScore > GoodScore.

test_scoring_uses_genre_weights() =>
    Pitches = twinkle_pitches(),
    % Classical has different weights than blues
    ScoreClassical = refiner.score_for_refinement(Pitches, 60, classical_period, []),
    ScoreBlues = refiner.score_for_refinement(Pitches, 60, blues, []),
    % They should be different (different weight profiles)
    ScoreClassical != ScoreBlues.

% ==============================================================================
% BOOSTING TESTS
% ==============================================================================

test_boost_returns_prefs() =>
    Pitches = chromatic_pitches(),
    BoostedPrefs = refiner.boost_worst_constraints(Pitches, 60, classical_period, [], 2),
    list(BoostedPrefs).

test_boost_has_overrides() =>
    Pitches = chromatic_pitches(),
    BoostedPrefs = refiner.boost_worst_constraints(Pitches, 60, classical_period, [], 2),
    % Should have weight_override entries
    Overrides = [P : P in BoostedPrefs, P = $weight_override(_, _)],
    length(Overrides) > 0,
    length(Overrides) =< 3.

test_boost_multiplier_increases() =>
    Pitches = chromatic_pitches(),
    Prefs2 = refiner.boost_worst_constraints(Pitches, 60, classical_period, [], 2),
    Prefs5 = refiner.boost_worst_constraints(Pitches, 60, classical_period, [], 5),
    % Extract max weight from each
    Weights2 = [W : P in Prefs2, P = $weight_override(_, W)],
    Weights5 = [W : P in Prefs5, P = $weight_override(_, W)],
    % Round 5 should have higher or equal weights than round 2
    max(Weights5) >= max(Weights2).

% ==============================================================================
% EXTRACTION TESTS
% ==============================================================================

test_extract_pitches() =>
    Notes = [
        $note($pitch(midi, 60, 4), $duration(1, 4), $time_pos(1, 1, 0), 1, 80),
        $note($pitch(midi, 62, 4), $duration(1, 4), $time_pos(1, 2, 0), 1, 80),
        $note($pitch(midi, 64, 4), $duration(1, 4), $time_pos(1, 3, 0), 1, 80)
    ],
    Pitches = refiner.extract_pitches(Notes),
    Pitches == [60, 62, 64].

test_extract_pitches_empty() =>
    Pitches = refiner.extract_pitches([]),
    Pitches == [].

% ==============================================================================
% HELPER TESTS
% ==============================================================================

test_get_refine_rounds_default() =>
    N = refiner.get_refine_rounds([]),
    N == 1.

test_get_refine_rounds_set() =>
    N = refiner.get_refine_rounds([refine=5, rhythm=on]),
    N == 5.

test_get_refine_piece_default() =>
    N = refiner.get_refine_piece_rounds([rhythm=on]),
    N == 1.

test_format_boosted() =>
    Prefs = [$weight_override(leap_recovery, 90), $weight_override(mostly_stepwise, 85)],
    Str = refiner.format_boosted(Prefs),
    % Should contain the constraint names
    length(Str) > 0.

test_ensure_min_randomness() =>
    Params = $music_params(120, major, 4, 5, soprano_voice(), 80, 15, 0.9, 0.0, 0.0),
    NewParams = refiner.ensure_min_randomness(Params, 0.4),
    NewR = get_randomness(NewParams),
    NewR >= 0.4.

test_ensure_min_randomness_high() =>
    Params = $music_params(120, major, 4, 5, soprano_voice(), 80, 15, 0.9, 0.0, 0.8),
    NewParams = refiner.ensure_min_randomness(Params, 0.4),
    NewR = get_randomness(NewParams),
    NewR >= 0.8.

% ==============================================================================
% INTEGRATION TESTS
% ==============================================================================

test_score_real_melody() =>
    % Generate a real melody
    Params = mood_to_params($mood(0.0, 0.0)),
    Prefs = [],
    once(melody.generate_segment_melody_with_genre(Params, 60, 4, classical_period, Prefs, Melody)),
    Pitches = refiner.extract_pitches(Melody),
    Score = refiner.score_for_refinement(Pitches, 60, classical_period, Prefs),
    integer(Score),
    Score >= 0.

test_boost_real_melody() =>
    % Generate a real melody and boost its worst constraints
    Params = mood_to_params($mood(0.0, 0.0)),
    Prefs = [],
    once(melody.generate_segment_melody_with_genre(Params, 60, 4, classical_period, Prefs, Melody)),
    Pitches = refiner.extract_pitches(Melody),
    BoostedPrefs = refiner.boost_worst_constraints(Pitches, 60, classical_period, Prefs, 2),
    Overrides = [P : P in BoostedPrefs, P = $weight_override(_, _)],
    % Should identify some constraints to boost (real melodies have violations)
    length(Overrides) > 0.
